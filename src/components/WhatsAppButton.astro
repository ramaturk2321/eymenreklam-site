---
import { getWhatsAppUrl, whatsappIcon } from '../lib/site-data';
import { contact } from '../lib/site-data';
---

<!-- Mobil: Alt sticky CTA bar (3 buton) -->
<div class="lg:hidden fixed bottom-0 left-0 right-0 z-40 bg-white border-t border-koyu-200 shadow-[0_-4px_12px_rgba(0,0,0,0.08)] grid grid-cols-3">
  <a
    href={contact.mobileHref}
    class="flex flex-col items-center justify-center gap-0.5 py-2.5 text-koyu-700 hover:bg-koyu-50 active:bg-koyu-100 transition-colors"
    aria-label="Telefon ile ara"
  >
    <svg class="w-5 h-5 text-eymen-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
    </svg>
    <span class="text-[11px] font-semibold">Ara</span>
  </a>
  <a
    href={getWhatsAppUrl()}
    target="_blank"
    rel="noopener noreferrer"
    class="flex flex-col items-center justify-center gap-0.5 py-2.5 bg-green-500 text-white active:bg-green-700 transition-colors"
    aria-label="WhatsApp ile iletişim"
  >
    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d={whatsappIcon}/></svg>
    <span class="text-[11px] font-bold">WhatsApp</span>
  </a>
  <a
    href="/iletisim/"
    class="flex flex-col items-center justify-center gap-0.5 py-2.5 bg-eymen-500 text-white active:bg-eymen-700 transition-colors"
    aria-label="Teklif al"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
    </svg>
    <span class="text-[11px] font-bold">Teklif Al</span>
  </a>
</div>

<!-- Mobil sticky bar için body padding -->
<style is:global>
  @media (max-width: 1023px) {
    body { padding-bottom: 64px; }
  }
</style>

<!-- Masaüstü: Floating WhatsApp Button — sağ alt köşe -->
<a
  href={getWhatsAppUrl()}
  target="_blank"
  rel="noopener noreferrer"
  class="hidden lg:flex fixed bottom-6 right-6 z-50 bg-green-500 hover:bg-green-600 text-white w-14 h-14 rounded-full items-center justify-center shadow-lg hover:shadow-xl transition-all hover:scale-110"
  aria-label="WhatsApp ile iletişime geçin"
>
  <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
    <path d={whatsappIcon}/>
  </svg>
</a>
