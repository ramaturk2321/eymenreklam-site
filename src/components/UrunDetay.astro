---
import { socialLinks, getWhatsAppUrl, whatsappMessages, whatsappIcon } from '../lib/site-data';

interface Props {
  title: string;
  description: string;
  product: {
    title: string;
    category: string;
    categoryHref: string;
    shortDesc: string;
    mainImg: string;
    gallery: string[];
    specs: { icon: string; label: string; value: string }[];
  };
  descriptionSections: {
    icon: string;
    title: string;
    content?: string;
    list?: { bold: string; text: string }[];
  }[];
  technicalSpecs: { label: string; value: string }[];
  faq: { q: string; a: string }[];
  relatedProducts: { img: string; title: string; href: string; category: string }[];
}

import BaseLayout from '../layouts/BaseLayout.astro';

const { title, description, product, descriptionSections, technicalSpecs, faq, relatedProducts } = Astro.props;
const waUrl = getWhatsAppUrl(whatsappMessages.product(product.title));

// FAQ Schema
const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

// Breadcrumb Schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: 'https://www.eymenreklam.com.tr' },
    { '@type': 'ListItem', position: 2, name: product.category, item: `https://www.eymenreklam.com.tr${product.categoryHref}` },
    { '@type': 'ListItem', position: 3, name: product.title },
  ],
};
---

<BaseLayout title={title} description={description}>

  <!-- Schema.org: FAQ + Breadcrumb -->
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Breadcrumb -->
  <nav class="bg-koyu-50 border-b border-koyu-100 py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ol class="flex items-center gap-2 text-sm text-koyu-500">
        <li><a href="/" class="hover:text-eymen-600 transition-colors">Ana Sayfa</a></li>
        <li class="text-koyu-300">/</li>
        <li><a href={product.categoryHref} class="hover:text-eymen-600 transition-colors">{product.category}</a></li>
        <li class="text-koyu-300">/</li>
        <li class="text-koyu-800 font-medium">{product.title}</li>
      </ol>
    </div>
  </nav>

  <!-- Ürün Üst: Görsel + Özet -->
  <section class="py-6 md:py-10 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-10">

        <!-- Sol: Görsel Galeri -->
        <div class="flex gap-3">
          <!-- Dikey Thumbnail Strip -->
          <div class="flex flex-col gap-2 shrink-0 max-h-[350px] md:max-h-[450px] overflow-y-auto">
            {product.gallery.map((img, i) => (
              <button
                class:list={[
                  'gallery-thumb w-16 h-16 md:w-20 md:h-20 rounded-lg overflow-hidden border-2 transition-all shrink-0',
                  i === 0 ? 'border-eymen-500 ring-1 ring-eymen-300' : 'border-koyu-200 hover:border-eymen-400'
                ]}
                data-img={img}
              >
                <img src={img} alt={`${product.title} ${i+1}`} width="80" height="80" loading="lazy" decoding="async" class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
          <!-- Ana Görsel -->
          <div class="relative flex-1 rounded-2xl overflow-hidden bg-koyu-100 group cursor-pointer h-[350px] md:h-[450px]" id="main-image-wrapper">
            <img id="main-product-image" src={product.mainImg} alt={product.title} width="800" height="450" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute top-4 right-4 w-10 h-10 bg-white/80 backdrop-blur rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
              <svg class="w-5 h-5 text-koyu-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
            </div>
          </div>
        </div>

        <!-- Sağ: Ürün Bilgileri -->
        <div>
          <a href={product.categoryHref} class="inline-flex items-center gap-1.5 bg-eymen-50 text-eymen-600 text-xs font-bold uppercase tracking-wider px-3 py-1.5 rounded-full mb-4 hover:bg-eymen-100 transition-colors">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
            {product.category}
          </a>

          <h1 class="text-3xl md:text-4xl font-bold text-koyu-900 mb-4 leading-tight">{product.title}</h1>
          <p class="text-koyu-600 leading-relaxed mb-4">{product.shortDesc}</p>

          <!-- Özellik İkon Kartları -->
          <div class="grid grid-cols-2 gap-3 mb-4">
            {product.specs.map(spec => (
              <div class="flex items-start gap-3 p-4 bg-koyu-50 rounded-xl">
                <div class="w-10 h-10 bg-eymen-100 text-eymen-600 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d={spec.icon}/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-koyu-400 font-medium uppercase tracking-wider">{spec.label}</div>
                  <div class="text-sm text-koyu-800 font-semibold mt-0.5">{spec.value}</div>
                </div>
              </div>
            ))}
          </div>

          <!-- CTA + Paylaş -->
          <div class="flex items-center gap-2 mb-4">
            <a
              href={waUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-1.5 bg-[#25D366] hover:bg-[#1fb855] text-white px-5 py-2.5 rounded-lg text-sm font-bold transition-all hover:shadow-lg hover:shadow-[#25D366]/25"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d={whatsappIcon}/></svg>
              Teklif Al
            </a>
            <span class="text-xs text-koyu-400 ml-1">Paylaş:</span>
            <a href={`https://www.linkedin.com/sharing/share-offsite/?url=https://www.eymenreklam.com.tr${Astro.url.pathname}`} target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-koyu-100 hover:bg-[#0A66C2] hover:text-white rounded-lg flex items-center justify-center text-koyu-500 transition-all flex-shrink-0" aria-label="LinkedIn'de Paylaş">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=https://www.eymenreklam.com.tr${Astro.url.pathname}`} target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-koyu-100 hover:bg-[#1877F2] hover:text-white rounded-lg flex items-center justify-center text-koyu-500 transition-all flex-shrink-0" aria-label="Facebook'ta Paylaş">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href={`https://twitter.com/intent/tweet?url=https://www.eymenreklam.com.tr${Astro.url.pathname}&text=${encodeURIComponent(product.title + ' | Eymen Reklam')}`} target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-koyu-100 hover:bg-black hover:text-white rounded-lg flex items-center justify-center text-koyu-500 transition-all flex-shrink-0" aria-label="X'te Paylaş">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tab Bar + İçerik -->
  <section class="bg-white">
    <div class="bg-koyu-600 shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex overflow-x-auto scrollbar-hide">
          <button class="product-tab whitespace-nowrap px-6 py-4 text-sm font-extrabold transition-all flex-shrink-0 bg-eymen-500 text-white" data-tab="aciklama">Açıklama</button>
          <button class="product-tab whitespace-nowrap px-6 py-4 text-sm font-semibold transition-all flex-shrink-0 text-koyu-300 hover:text-white hover:bg-koyu-500" data-tab="teknik">Teknik Özellikler</button>
          <button class="product-tab whitespace-nowrap px-6 py-4 text-sm font-semibold transition-all flex-shrink-0 text-koyu-300 hover:text-white hover:bg-koyu-500" data-tab="sss">Sıkça Sorulan Sorular</button>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 md:py-6">
      <!-- Açıklama -->
      <div class="product-panel" data-panel="aciklama">
        <div class="space-y-4">
          {descriptionSections.map(section => (
            <div class="bg-koyu-50/60 rounded-xl p-5 md:p-6 border border-koyu-100">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-eymen-100 text-eymen-600 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d={section.icon}/>
                  </svg>
                </div>
                <h3 class="text-lg md:text-xl font-bold text-koyu-900">{section.title}</h3>
              </div>
              {section.content && (
                <p class="text-koyu-600 leading-relaxed text-[15px]">{section.content}</p>
              )}
              {section.list && (
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-2">
                  {section.list.map(item => (
                    <div class="flex items-start gap-2.5 bg-white rounded-xl p-4 border border-koyu-100">
                      <div class="w-2 h-2 bg-eymen-500 rounded-full mt-2 flex-shrink-0"></div>
                      <div>
                        <span class="font-semibold text-koyu-800 text-sm">{item.bold}</span>
                        <p class="text-koyu-500 text-sm mt-0.5 leading-relaxed">{item.text}</p>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- Teknik Özellikler -->
      <div class="product-panel hidden" data-panel="teknik">
        <div class="bg-koyu-50/60 rounded-xl p-5 md:p-6 border border-koyu-100">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-eymen-100 text-eymen-600 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            </div>
            <h3 class="text-lg md:text-xl font-bold text-koyu-900">Teknik Özellikler</h3>
          </div>
          <div class="rounded-xl overflow-hidden border border-koyu-100 bg-white">
            <table class="w-full">
              <tbody>
                {technicalSpecs.map((spec, i) => (
                  <tr class:list={[i % 2 === 0 ? 'bg-white' : 'bg-koyu-50/50']}>
                    <td class="px-6 py-4 text-sm font-semibold text-koyu-700 whitespace-nowrap border-r border-koyu-100 w-1/3">
                      <div class="flex items-center gap-2.5">
                        <div class="w-1.5 h-1.5 bg-eymen-500 rounded-full flex-shrink-0"></div>
                        {spec.label}
                      </div>
                    </td>
                    <td class="px-6 py-4 text-sm text-koyu-600">{spec.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- SSS -->
      <div class="product-panel hidden" data-panel="sss">
        <div class="bg-koyu-50/60 rounded-xl p-5 md:p-6 border border-koyu-100">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 bg-eymen-100 text-eymen-600 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="text-lg md:text-xl font-bold text-koyu-900">Sıkça Sorulan Sorular</h3>
          </div>
          <div class="space-y-3">
            {faq.map((item, i) => (
              <div class="bg-white border border-koyu-100 rounded-xl overflow-hidden">
                <button class="faq-btn w-full flex items-center justify-between px-5 py-4 text-left hover:bg-koyu-50/50 transition-colors">
                  <div class="flex items-center gap-3 pr-4">
                    <span class="w-7 h-7 bg-eymen-100 text-eymen-600 rounded-lg flex items-center justify-center flex-shrink-0 text-xs font-bold">{i + 1}</span>
                    <span class="text-[15px] font-semibold text-koyu-800">{item.q}</span>
                  </div>
                  <svg class="faq-icon w-5 h-5 text-koyu-400 flex-shrink-0 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="faq-content hidden px-5 pb-4 pl-15">
                  <p class="text-sm text-koyu-600 leading-relaxed">{item.a}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- İlgili Ürünler -->
  <section class="py-4 md:py-6 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-koyu-900 mb-4">İlgili Ürünler</h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
        {relatedProducts.map(p => (
          <a href={p.href} class="group block">
            <div class="relative rounded-xl overflow-hidden bg-koyu-100 aspect-[4/3] mb-3">
              <img src={p.img} alt={p.title} width="400" height="300" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute inset-0 bg-koyu-900/0 group-hover:bg-koyu-900/30 transition-all duration-300 flex items-center justify-center">
                <span class="opacity-0 group-hover:opacity-100 transition-opacity w-10 h-10 bg-eymen-500 rounded-full flex items-center justify-center">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </span>
              </div>
            </div>
            <span class="text-xs text-koyu-400 font-medium uppercase tracking-wider">{p.category}</span>
            <h3 class="text-sm font-semibold text-koyu-800 group-hover:text-eymen-600 transition-colors mt-1">{p.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
</style>

<script>
  // Gallery thumbnail click
  const mainImg = document.getElementById('main-product-image') as HTMLImageElement;
  const thumbs = document.querySelectorAll('.gallery-thumb');

  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => {
      const src = (thumb as HTMLElement).dataset.img;
      if (mainImg && src) mainImg.src = src;
      thumbs.forEach(t => t.className = 'gallery-thumb w-16 h-16 md:w-20 md:h-20 rounded-lg overflow-hidden border-2 transition-all shrink-0 border-koyu-200 hover:border-eymen-400');
      thumb.className = 'gallery-thumb w-16 h-16 md:w-20 md:h-20 rounded-lg overflow-hidden border-2 transition-all shrink-0 border-eymen-500 ring-1 ring-eymen-300';
    });
  });

  // Product tabs
  const ptabs = document.querySelectorAll('.product-tab');
  const ppanels = document.querySelectorAll('.product-panel');

  ptabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;
      ptabs.forEach(t => {
        t.className = 'product-tab whitespace-nowrap px-6 py-4 text-sm font-semibold transition-all flex-shrink-0 text-koyu-300 hover:text-white hover:bg-koyu-500';
      });
      tab.className = 'product-tab whitespace-nowrap px-6 py-4 text-sm font-extrabold transition-all flex-shrink-0 bg-eymen-500 text-white';
      ppanels.forEach(p => p.classList.add('hidden'));
      document.querySelector(`[data-panel="${target}"]`)?.classList.remove('hidden');
    });
  });

  // FAQ accordion
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling;
      const icon = btn.querySelector('.faq-icon');
      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
