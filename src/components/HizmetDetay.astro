---
interface Props {
  title: string;
  description: string;
  heroDesc: string;
  features: { icon: string; title: string; desc: string }[];
  products: { title: string; desc: string; image: string; href: string }[];
  process: { step: string; title: string; desc: string }[];
  sectors: string[];
  faq: { q: string; a: string }[];
}

import BaseLayout from '../layouts/BaseLayout.astro';

const { title, description, heroDesc, features, products, process, sectors, faq } = Astro.props;
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="bg-koyu-900 pt-32 pb-16 md:pt-40 md:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-eymen-400 text-sm font-semibold uppercase tracking-wider mb-3">Eymen Reklam Hizmetleri</p>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-6">{title}</h1>
        <p class="text-koyu-300 text-lg leading-relaxed mb-8">{heroDesc}</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/teklif-al" class="inline-flex items-center justify-center gap-2 bg-eymen-500 hover:bg-eymen-600 text-white px-8 py-4 rounded-xl text-base font-semibold transition-all hover:shadow-lg hover:shadow-eymen-500/25">
            Kurumsal Teklif Alın
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="tel:+902163790708" class="inline-flex items-center justify-center gap-2 border border-koyu-600 hover:border-koyu-400 text-koyu-200 hover:text-white px-8 py-4 rounded-xl text-base font-semibold transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            (0216) 379 07 08
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Özellikler -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-900">Neden Eymen Reklam?</h2>
        <p class="text-koyu-500 mt-4">25 yıllık deneyimle kurumsal müşterilerimize sunduğumuz avantajlar.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map(f => (
          <div class="bg-koyu-50 rounded-2xl p-7 border border-koyu-100 hover:border-eymen-200 hover:shadow-lg transition-all duration-300">
            <span class="text-3xl block mb-4">{f.icon}</span>
            <h3 class="text-lg font-bold text-koyu-900 mb-2">{f.title}</h3>
            <p class="text-sm text-koyu-500 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Ürünler -->
  <section class="py-16 md:py-24 bg-koyu-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-eymen-500 text-sm font-semibold uppercase tracking-wider mb-3">Ürün Yelpazesi</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-900">{title} Çözümlerimiz</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {products.map(p => (
          <a href={p.href} class="group bg-white rounded-2xl border border-koyu-100 overflow-hidden hover:shadow-xl hover:border-eymen-200 transition-all duration-300 hover:-translate-y-1">
            <div class="aspect-[4/3] overflow-hidden bg-koyu-200">
              <img src={p.image} alt={p.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <h3 class="font-bold text-koyu-900 mb-2 group-hover:text-eymen-600 transition-colors">{p.title}</h3>
              <p class="text-sm text-koyu-500 leading-relaxed">{p.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Süreç -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-eymen-500 text-sm font-semibold uppercase tracking-wider mb-3">Çalışma Sürecimiz</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-900">Keşiften Montaja</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {process.map(p => (
          <div class="text-center">
            <div class="w-14 h-14 bg-eymen-500 text-white rounded-2xl flex items-center justify-center text-xl font-bold mx-auto mb-4">{p.step}</div>
            <h3 class="font-bold text-koyu-900 mb-2">{p.title}</h3>
            <p class="text-sm text-koyu-500">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sektörler -->
  <section class="py-16 md:py-24 bg-koyu-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Hizmet Verdiğimiz Sektörler</h2>
        <div class="w-12 h-1 bg-eymen-500 mx-auto mt-4"></div>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {sectors.map(s => (
          <span class="px-5 py-2.5 bg-koyu-800 text-koyu-200 text-sm font-medium rounded-full border border-koyu-700">
            {s}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- SSS -->
  {faq.length > 0 && (
    <section class="py-16 md:py-24 bg-koyu-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-900">Sık Sorulan Sorular</h2>
        </div>
        <div class="space-y-4">
          {faq.map(f => (
            <details class="group bg-white rounded-xl border border-koyu-100 overflow-hidden">
              <summary class="flex items-center justify-between cursor-pointer p-5 font-semibold text-koyu-900 hover:text-eymen-600 transition-colors">
                {f.q}
                <svg class="w-5 h-5 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-5 pb-5 text-sm text-koyu-500 leading-relaxed">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-gradient-to-br from-eymen-500 to-eymen-700 py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">Projeniz İçin Kurumsal Teklif Alın</h2>
      <p class="text-eymen-100 text-lg mb-8 max-w-2xl mx-auto">
        Uzman ekibimiz projenizi yerinde inceler, 3D ön izleme hazırlar ve detaylı fiyat teklifi sunar. 24 saat içinde dönüş garantisi.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/teklif-al" class="inline-flex items-center justify-center gap-2 bg-white text-eymen-600 hover:bg-koyu-50 px-8 py-4 rounded-xl text-base font-bold transition-all hover:shadow-lg">
          Kurumsal Teklif Formu
        </a>
        <a href="tel:+902163790708" class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white/60 text-white px-8 py-4 rounded-xl text-base font-semibold transition-all">
          (0216) 379 07 08
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
