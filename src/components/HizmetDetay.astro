---
interface Props {
  title: string;
  description: string;
  heroDesc: string;
  heroImage?: string;
  facility?: {
    title: string;
    description: string;
    stats: { value: string; label: string }[];
    machines: string[];
    images: string[];
  };
  features: { icon: string; title: string; desc: string }[];
  products: { title: string; desc: string; image: string; href: string }[];
  process: { step: string; title: string; desc: string }[];
  sectors: string[];
  faq: { q: string; a: string }[];
}

import BaseLayout from '../layouts/BaseLayout.astro';
import { company, contact, getWhatsAppUrl, whatsappMessages } from '../lib/site-data';

const { title, description, heroDesc, heroImage, facility, features, products, process, sectors, faq } = Astro.props;

// FAQ Schema
const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

// Breadcrumb Schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: company.siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Hizmetlerimiz', item: `${company.siteUrl}/hizmetlerimiz/` },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};
---

<BaseLayout title={title} description={description}>

  <!-- Schema.org: FAQ + Breadcrumb -->
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Breadcrumb -->
  <nav class="bg-koyu-50 border-b border-koyu-100 py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ol class="flex items-center gap-2 text-sm text-koyu-500">
        <li><a href="/" class="hover:text-eymen-600 transition-colors">Ana Sayfa</a></li>
        <li class="text-koyu-300">/</li>
        <li><a href="/hizmetlerimiz/" class="hover:text-eymen-600 transition-colors">Hizmetlerimiz</a></li>
        <li class="text-koyu-300">/</li>
        <li class="text-koyu-800 font-medium">{title}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative bg-koyu-900 overflow-hidden pt-12 pb-12 md:pt-20 md:pb-20">
    {heroImage && (
      <>
        <img src={heroImage} alt="" class="absolute inset-0 w-full h-full object-cover opacity-70" loading="eager" decoding="async" />
        <div class="absolute inset-0 bg-gradient-to-r from-koyu-900/90 via-koyu-900/60 to-koyu-900/20"></div>
      </>
    )}
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-eymen-400 text-sm font-semibold tracking-wider mb-3">EYMEN REKLAM HİZMETLERİ</p>
        <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-4">{title}</h1>
        <p class="text-koyu-200 text-base md:text-lg leading-relaxed mb-6 md:mb-8">{heroDesc}</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/iletisim/" class="inline-flex items-center justify-center gap-2 bg-eymen-500 hover:bg-eymen-600 text-white px-6 py-3.5 rounded-xl text-sm md:text-base font-bold transition-all hover:shadow-lg hover:shadow-eymen-500/25">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Ücretsiz Teklif Alın
          </a>
          <a href={getWhatsAppUrl(whatsappMessages.product(title))} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-green-600 hover:bg-green-700 text-white px-6 py-3.5 rounded-xl text-sm md:text-base font-bold transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.75.75 0 00.913.913l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            WhatsApp ile Yaz
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Üretim Tesisi -->
  {facility && (
    <section class="py-12 md:py-20 bg-koyu-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-10 md:mb-12">
          <p class="text-eymen-500 text-sm font-semibold tracking-wider mb-3">ÜRETİM TESİSİ</p>
          <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-900 mb-4">{facility.title}</h2>
          <p class="text-koyu-500 leading-relaxed">{facility.description}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 mb-8 md:mb-10">
          {facility.images.map((img, i) => (
            <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-koyu-200 shadow-md">
              <img src={img} alt={`${facility.title} - Üretim ${i + 1}`} loading="lazy" decoding="async" class="w-full h-full object-cover" />
            </div>
          ))}
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-6 mb-8">
          {facility.stats.map(s => (
            <div class="bg-white rounded-2xl p-4 md:p-6 text-center border border-koyu-100">
              <div class="text-xl md:text-3xl font-extrabold text-eymen-600 mb-1">{s.value}</div>
              <div class="text-xs md:text-sm text-koyu-500 font-medium leading-tight">{s.label}</div>
            </div>
          ))}
        </div>

        <div class="bg-white rounded-2xl p-6 md:p-8 border border-koyu-100">
          <h3 class="font-bold text-koyu-900 mb-4 text-base md:text-lg">Makine Parkurumuz</h3>
          <ul class="space-y-2.5">
            {facility.machines.map(m => (
              <li class="flex items-start gap-3 text-sm md:text-base text-koyu-700">
                <svg class="w-5 h-5 flex-shrink-0 text-eymen-500 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span>{m}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )}

  <!-- Ürünler (hemen hero altında) -->
  <section class="py-10 md:py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 gap-4 md:gap-6">
        {products.map(p => (
          <a href={p.href} class="group bg-white rounded-xl border border-koyu-100 overflow-hidden hover:shadow-xl hover:border-eymen-200 transition-all duration-300 hover:-translate-y-1">
            <div class="aspect-[4/3] overflow-hidden bg-koyu-200">
              <img src={p.image} alt={p.title} width="400" height="300" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-3 md:p-5">
              <h3 class="font-bold text-sm md:text-base text-koyu-900 mb-1 group-hover:text-eymen-600 transition-colors">{p.title}</h3>
              <p class="text-xs md:text-sm text-koyu-500 leading-relaxed hidden sm:block">{p.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Özellikler -->
  <section class="py-12 md:py-20 bg-koyu-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-900">Neden Eymen Reklam?</h2>
        <p class="text-koyu-500 mt-4">25 yıllık deneyimle kurumsal müşterilerimize sunduğumuz avantajlar.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map(f => (
          <div class="bg-white rounded-2xl p-7 border border-koyu-100 hover:border-eymen-200 hover:shadow-lg transition-all duration-300">
            <span class="text-3xl block mb-4">{f.icon}</span>
            <h3 class="text-lg font-bold text-koyu-900 mb-2">{f.title}</h3>
            <p class="text-sm text-koyu-500 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Süreç -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-eymen-500 text-sm font-semibold tracking-wider mb-3">ÇALIŞMA SÜRECİMİZ</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-900">Keşiften Montaja</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {process.map(p => (
          <div class="text-center">
            <div class="w-14 h-14 bg-eymen-500 text-white rounded-2xl flex items-center justify-center text-xl font-bold mx-auto mb-4">{p.step}</div>
            <h3 class="font-bold text-koyu-900 mb-2">{p.title}</h3>
            <p class="text-sm text-koyu-500">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sektörler -->
  <section class="py-16 md:py-24 bg-koyu-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Hizmet Verdiğimiz Sektörler</h2>
        <div class="w-12 h-1 bg-eymen-500 mx-auto mt-4"></div>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {sectors.map(s => (
          <span class="px-5 py-2.5 bg-koyu-800 text-koyu-200 text-sm font-medium rounded-full border border-koyu-700">
            {s}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- SSS -->
  {faq.length > 0 && (
    <section class="py-16 md:py-24 bg-koyu-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-900">Sık Sorulan Sorular</h2>
        </div>
        <div class="space-y-4">
          {faq.map(f => (
            <details class="group bg-white rounded-xl border border-koyu-100 overflow-hidden">
              <summary class="flex items-center justify-between cursor-pointer p-5 font-semibold text-koyu-900 hover:text-eymen-600 transition-colors">
                {f.q}
                <svg class="w-5 h-5 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-5 pb-5 text-sm text-koyu-500 leading-relaxed">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-gradient-to-br from-eymen-500 to-eymen-700 py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">Projeniz İçin Kurumsal Teklif Alın</h2>
      <p class="text-eymen-100 text-lg mb-8 max-w-2xl mx-auto">
        Uzman ekibimiz projenizi yerinde inceler, 3D ön izleme hazırlar ve detaylı fiyat teklifi sunar. 24 saat içinde dönüş garantisi.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/teklif-al" class="inline-flex items-center justify-center gap-2 bg-white text-eymen-600 hover:bg-koyu-50 px-8 py-4 rounded-xl text-base font-bold transition-all hover:shadow-lg">
          Kurumsal Teklif Formu
        </a>
        <a href={contact.phoneHref} class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white/60 text-white px-8 py-4 rounded-xl text-base font-semibold transition-all">
          {contact.phone}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
