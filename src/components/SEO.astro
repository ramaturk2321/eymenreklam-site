---
import { contact, company } from '../lib/site-data';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
}

const { title, description, image = '/images/fabrika.png', type = 'website' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'Organization'],
  name: company.name,
  legalName: company.fullName,
  description: company.slogan,
  url: company.siteUrl,
  logo: new URL(company.logoPath, Astro.site).toString(),
  telephone: contact.phoneHref.replace('tel:', ''),
  email: contact.email,
  foundingDate: String(company.founded),
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Esenler Mah. Çevre Sk. No: 7',
    addressLocality: 'Pendik',
    addressRegion: 'İstanbul',
    postalCode: '34890',
    addressCountry: 'TR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 40.8803,
    longitude: 29.2336,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '18:30',
    },
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+905356647752',
    contactType: 'customer service',
    availableLanguage: 'Turkish',
  },
  image: imageURL.toString(),
  priceRange: '$$',
  areaServed: {
    '@type': 'City',
    name: 'İstanbul',
  },
  sameAs: [
    'https://www.instagram.com/eymenreklamltd/',
    'https://www.youtube.com/@eymenreklamltd',
    'https://www.linkedin.com/company/eymenreklamltd/',
    'https://www.facebook.com/eymenreklamltd/',
    'https://www.eymenreklam.com',
    'https://www.pendikuvbaski.com',
    'https://www.pendikbezbaski.com',
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Reklam ve Baskı Hizmetleri',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Tabela İmalatı' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'UV Baskı' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Afiş Baskı' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Bez / Branda Baskı' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Dijital Baskı' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Folyo & Araç Giydirme' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Grafik Tasarım' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'İş Güvenliği Levhaları' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Mağaza Reklam Uygulamaları' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Sunum & Stand' } },
    ],
  },
};
---

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={`${title} | Eymen Reklam`} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:locale" content="tr_TR" />
<meta property="og:site_name" content="Eymen Reklam" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={`${title} | Eymen Reklam`} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
