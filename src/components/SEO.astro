---
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
}

const { title, description, image = '/images/fabrika.png', type = 'website' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Eymen Reklam',
  description: 'Tabela İmalatı, UV Baskı, Dijital Baskı ve Araç Giydirme — Pendik İstanbul',
  url: 'https://eymenreklam.com',
  telephone: '+902163790708',
  email: 'info@eymenreklam.com',
  foundingDate: '1999',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Esenler Mah. Çevre Sk. No: 7',
    addressLocality: 'Pendik',
    addressRegion: 'İstanbul',
    postalCode: '34899',
    addressCountry: 'TR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 40.88,
    longitude: 29.25,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '09:00',
    closes: '18:30',
  },
  image: imageURL.toString(),
  priceRange: '$$',
  areaServed: {
    '@type': 'City',
    name: 'İstanbul',
  },
};
---

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={`${title} | Eymen Reklam`} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:locale" content="tr_TR" />
<meta property="og:site_name" content="Eymen Reklam" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={`${title} | Eymen Reklam`} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
