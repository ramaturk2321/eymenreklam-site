---
const hizmetler = [
  { href: '/hizmetlerimiz/tabela', label: 'Tabela İmalatı', icon: '🔤' },
  { href: '/hizmetlerimiz/uv-baski', label: 'UV Baskı', icon: '🖨️' },
  { href: '/hizmetlerimiz/dijital-baski', label: 'Dijital Baskı', icon: '📄' },
  { href: '/hizmetlerimiz/folyo-giydirme', label: 'Folyo & Giydirme', icon: '🚗' },
  { href: '/hizmetlerimiz/bez-baski', label: 'Bez Baskı', icon: '🏗️' },
  { href: '/hizmetlerimiz/afis-baski', label: 'Afiş Baskı', icon: '🖼️' },
  { href: '/hizmetlerimiz/sunum-stand', label: 'Sunum & Stand', icon: '📐' },
  { href: '/hizmetlerimiz/is-guvenligi', label: 'İş Güvenliği Levhaları', icon: '⚠️' },
  { href: '/hizmetlerimiz/magaza-reklam', label: 'Mağaza Reklam', icon: '🏢' },
];

const urunler = [
  {
    category: 'Tabela',
    items: [
      { href: '/urunlerimiz/kutu-harf-tabela', label: 'Kutu Harf Tabela' },
      { href: '/urunlerimiz/totem-tabela', label: 'Totem Tabela' },
      { href: '/urunlerimiz/cati-tabelasi', label: 'Çatı Tabelası' },
      { href: '/urunlerimiz/neon-led-tabela', label: 'Neon-Led Tabela' },
      { href: '/urunlerimiz/isikli-blok-tabela', label: 'Işıklı Blok Tabela' },
      { href: '/urunlerimiz/ofis-tabelasi', label: 'Ofis Tabelası' },
    ]
  },
  {
    category: 'Folyo & Araç',
    items: [
      { href: '/urunlerimiz/komple-arac-kaplama', label: 'Komple Araç Kaplama' },
      { href: '/urunlerimiz/kismi-arac-kaplama', label: 'Kısmi Araç Kaplama' },
      { href: '/urunlerimiz/cephe-folyo-giydirme', label: 'Cephe Folyo Giydirme' },
      { href: '/urunlerimiz/cam-folyo-giydirme', label: 'Cam Folyo Giydirme' },
      { href: '/urunlerimiz/folyo-harf-kesim', label: 'Folyo Harf Kesim' },
      { href: '/urunlerimiz/kamyon-tir-giydirme', label: 'Kamyon/Tır Giydirme' },
    ]
  },
  {
    category: 'Baskı & Display',
    items: [
      { href: '/urunlerimiz/branda-baski', label: 'Branda Baskı' },
      { href: '/urunlerimiz/mesh-branda', label: 'Mesh Branda Baskı' },
      { href: '/urunlerimiz/pankart-branda', label: 'Pankart Branda Baskı' },
      { href: '/urunlerimiz/lightbox-pano', label: 'Lightbox Pano' },
      { href: '/urunlerimiz/roll-up-banner', label: 'Roll-Up Banner' },
      { href: '/urunlerimiz/dijital-baski', label: 'Dijital Baskı Ürünleri' },
    ]
  },
];

const navLinks = [
  { href: '/projelerimiz', label: 'Projelerimiz' },
  { href: '/hakkimizda', label: 'Hakkımızda' },
  { href: '/iletisim', label: 'İletişim' },
];

const currentPath = Astro.url.pathname;
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-koyu-100 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20 md:h-24">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img src="/images/eymen-logo.png" alt="Eymen Reklam" class="h-16 md:h-[100px] w-auto" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        <!-- Hizmetlerimiz Dropdown -->
        <div class="relative group" id="hizmet-dropdown">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium rounded-lg text-koyu-600 hover:text-koyu-900 hover:bg-koyu-50 transition-colors">
            Hizmetlerimiz
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <!-- Mega Menu -->
          <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-200 absolute top-full left-0 pt-2 z-50">
            <div class="bg-white rounded-2xl shadow-2xl border border-koyu-100 p-6 w-[700px]">
              <div class="grid grid-cols-3 gap-3">
                {hizmetler.map(h => (
                  <a href={h.href} class="flex items-center gap-3 p-3 rounded-xl hover:bg-eymen-50 transition-colors group/item">
                    <span class="text-xl">{h.icon}</span>
                    <span class="text-sm font-medium text-koyu-700 group-hover/item:text-eymen-600 transition-colors">{h.label}</span>
                  </a>
                ))}
              </div>
              <div class="mt-4 pt-4 border-t border-koyu-100">
                <a href="/hizmetlerimiz" class="text-sm text-eymen-600 font-semibold hover:text-eymen-700 transition-colors">
                  Tüm Hizmetleri Görüntüle →
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Ürünlerimiz Dropdown -->
        <div class="relative group" id="urun-dropdown">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium rounded-lg text-koyu-600 hover:text-koyu-900 hover:bg-koyu-50 transition-colors">
            Ürünlerimiz
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <!-- Mega Menu -->
          <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-200 absolute top-full -left-20 pt-2 z-50">
            <div class="bg-white rounded-2xl shadow-2xl border border-koyu-100 p-6 w-[680px]">
              <div class="grid grid-cols-3 gap-6">
                {urunler.map(group => (
                  <div>
                    <h4 class="text-xs font-bold text-koyu-400 uppercase tracking-wider mb-3">{group.category}</h4>
                    <div class="space-y-1">
                      {group.items.map(item => (
                        <a href={item.href} class="block px-3 py-2 text-sm text-koyu-600 rounded-lg hover:bg-eymen-50 hover:text-eymen-600 transition-colors">
                          {item.label}
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
              <div class="mt-4 pt-4 border-t border-koyu-100">
                <a href="/urunlerimiz" class="text-sm text-eymen-600 font-semibold hover:text-eymen-700 transition-colors">
                  Tüm Ürünleri Görüntüle →
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Normal Links -->
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-2 text-sm font-medium rounded-lg transition-colors',
              currentPath === link.href
                ? 'text-eymen-600 bg-eymen-50'
                : 'text-koyu-600 hover:text-koyu-900 hover:bg-koyu-50'
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA + Mobile -->
      <div class="flex items-center gap-3">
        <!-- Kurumsal Teklif CTA Desktop -->
        <a
          href="/teklif-al"
          class="hidden lg:inline-flex items-center gap-2 bg-eymen-500 hover:bg-eymen-600 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Kurumsal Teklif Al
        </a>

        <!-- Telefon Desktop -->
        <a
          href="tel:+902163790708"
          class="hidden xl:inline-flex items-center gap-2 text-koyu-600 hover:text-koyu-900 text-sm font-medium"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          (0216) 379 07 08
        </a>

        <!-- Dil Seçimi -->
        <div class="hidden lg:flex items-center border-l border-koyu-200 pl-3 ml-1">
          <a href="/" class="px-2 py-1 text-xs font-bold text-eymen-600 bg-eymen-50 rounded">TR</a>
          <a href="/en" class="px-2 py-1 text-xs font-medium text-koyu-400 hover:text-koyu-700 rounded transition-colors">EN</a>
        </div>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-lg text-koyu-600 hover:bg-koyu-50" aria-label="Menü">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-koyu-100 bg-white max-h-[80vh] overflow-y-auto">
    <div class="px-4 py-4 space-y-1">
      <!-- Hizmetler Accordion -->
      <div>
        <button class="mobile-accordion-btn w-full flex items-center justify-between px-4 py-3 rounded-lg text-sm font-medium text-koyu-600 hover:bg-koyu-50">
          Hizmetlerimiz
          <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-accordion-content hidden pl-4 space-y-1">
          {hizmetler.map(h => (
            <a href={h.href} class="flex items-center gap-2 px-4 py-2 text-sm text-koyu-500 hover:text-eymen-600 hover:bg-koyu-50 rounded-lg">
              <span>{h.icon}</span> {h.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Ürünler Accordion -->
      <div>
        <button class="mobile-accordion-btn w-full flex items-center justify-between px-4 py-3 rounded-lg text-sm font-medium text-koyu-600 hover:bg-koyu-50">
          Ürünlerimiz
          <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-accordion-content hidden pl-4 space-y-1">
          {urunler.map(group => (
            <div class="mb-2">
              <p class="px-4 py-1 text-xs font-bold text-koyu-400 uppercase">{group.category}</p>
              {group.items.map(item => (
                <a href={item.href} class="block px-4 py-2 text-sm text-koyu-500 hover:text-eymen-600 hover:bg-koyu-50 rounded-lg">
                  {item.label}
                </a>
              ))}
            </div>
          ))}
        </div>
      </div>

      {navLinks.map(link => (
        <a href={link.href} class="block px-4 py-3 rounded-lg text-sm font-medium text-koyu-600 hover:bg-koyu-50">
          {link.label}
        </a>
      ))}
      <a href="/teklif-al" class="block w-full text-center bg-eymen-500 hover:bg-eymen-600 text-white px-4 py-3 rounded-lg text-sm font-semibold mt-3">
        Kurumsal Teklif Al
      </a>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Mobile accordion
  document.querySelectorAll('.mobile-accordion-btn').forEach(b => {
    b.addEventListener('click', () => {
      const content = b.nextElementSibling;
      const icon = b.querySelector('svg');
      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
