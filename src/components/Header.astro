---
const hizmetler = [
  { href: '/hizmetlerimiz/tabela', label: 'Tabela', icon: '🔤' },
  { href: '/hizmetlerimiz/dijital-baski', label: 'Dijital Baskı', icon: '🖨️' },
  { href: '/hizmetlerimiz/uv-baski', label: 'UV Baskı', icon: '☀️' },
  { href: '/hizmetlerimiz/folyo-giydirme', label: 'Folyo & Giydirme', icon: '🚗' },
  { href: '/hizmetlerimiz/sunum-stand', label: 'Display & Stand', icon: '📐' },
  { href: '/hizmetlerimiz/bez-baski', label: 'Bez & Afiş Baskı', icon: '🖼️' },
  { href: '/hizmetlerimiz/grafik-tasarim', label: 'Grafik Tasarım', icon: '🎨' },
  { href: '/hizmetlerimiz/magaza-reklam', label: 'Kurumsal Hizmetler', icon: '🏢' },
];

const urunler = [
  {
    category: 'Tabela',
    items: [
      { href: '/urunlerimiz/kutu-harf-tabela', label: 'Kutu Harf Tabela' },
      { href: '/urunlerimiz/totem-tabela', label: 'Totem Tabela' },
      { href: '/urunlerimiz/cati-tabelasi', label: 'Çatı Tabelası' },
      { href: '/urunlerimiz/neon-led-tabela', label: 'Neon-Led Tabela' },
      { href: '/urunlerimiz/isikli-blok-tabela', label: 'Işıklı Blok Tabela' },
      { href: '/urunlerimiz/ofis-tabelasi', label: 'Ofis Tabelası' },
    ]
  },
  {
    category: 'Folyo & Araç',
    items: [
      { href: '/urunlerimiz/komple-arac-kaplama', label: 'Komple Araç Kaplama' },
      { href: '/urunlerimiz/kismi-arac-kaplama', label: 'Kısmi Araç Kaplama' },
      { href: '/urunlerimiz/cephe-folyo-giydirme', label: 'Cephe Folyo Giydirme' },
      { href: '/urunlerimiz/cam-folyo-giydirme', label: 'Cam Folyo Giydirme' },
      { href: '/urunlerimiz/folyo-harf-kesim', label: 'Folyo Harf Kesim' },
      { href: '/urunlerimiz/kamyon-tir-giydirme', label: 'Kamyon/Tır Giydirme' },
    ]
  },
  {
    category: 'Baskı & Display',
    items: [
      { href: '/urunlerimiz/branda-baski', label: 'Branda Baskı' },
      { href: '/urunlerimiz/mesh-branda', label: 'Mesh Branda Baskı' },
      { href: '/urunlerimiz/pankart-branda', label: 'Pankart Branda Baskı' },
      { href: '/urunlerimiz/lightbox-pano', label: 'Lightbox Pano' },
      { href: '/urunlerimiz/roll-up-banner', label: 'Roll-Up Banner' },
      { href: '/urunlerimiz/dijital-baski', label: 'Dijital Baskı Ürünleri' },
    ]
  },
];

const navLinks = [
  { href: '/projelerimiz', label: 'Projelerimiz' },
  { href: '/hakkimizda', label: 'Hakkımızda' },
  { href: '/iletisim', label: 'İletişim' },
];

const currentPath = Astro.url.pathname;
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <!-- ===== ÜST BİLGİ BARI ===== -->
  <div class="bg-koyu-800 text-koyu-300 hidden lg:block">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-10">
        <!-- Sol: Telefon + E-posta -->
        <div class="flex items-center gap-6 text-sm">
          <a href="tel:+902163790708" class="flex items-center gap-2 hover:text-white transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            (0216) 379 07 08
          </a>
          <a href="tel:+905356647752" class="flex items-center gap-2 hover:text-white transition-colors font-semibold text-white">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            0535 664 77 52
          </a>
          <a href="mailto:info@eymenreklam.com.tr" class="flex items-center gap-2 hover:text-white transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            info@eymenreklam.com.tr
          </a>
        </div>

        <!-- Sağ: Dil + Sosyal Medya -->
        <div class="flex items-center gap-4">
          <!-- Dil Seçimi -->
          <div class="flex items-center gap-1 border-r border-koyu-600 pr-4">
            <a href="/" class="px-2 py-0.5 text-xs font-bold text-eymen-400 bg-koyu-700 rounded">TR</a>
            <a href="/en" class="px-2 py-0.5 text-xs font-medium text-koyu-400 hover:text-white rounded transition-colors">EN</a>
          </div>
          <!-- Sosyal Medya -->
          <div class="flex items-center gap-3">
            <a href="https://www.instagram.com/eymenreklam/" target="_blank" rel="noopener noreferrer" class="w-7 h-7 bg-koyu-700 hover:bg-eymen-500 rounded-full flex items-center justify-center transition-colors" aria-label="Instagram">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="https://www.youtube.com/@eymenreklam" target="_blank" rel="noopener noreferrer" class="w-7 h-7 bg-koyu-700 hover:bg-eymen-500 rounded-full flex items-center justify-center transition-colors" aria-label="YouTube">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
            <a href="https://www.linkedin.com/company/eymenreklam/" target="_blank" rel="noopener noreferrer" class="w-7 h-7 bg-koyu-700 hover:bg-eymen-500 rounded-full flex items-center justify-center transition-colors" aria-label="LinkedIn">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="https://www.facebook.com/eymenreklam/" target="_blank" rel="noopener noreferrer" class="w-7 h-7 bg-koyu-700 hover:bg-eymen-500 rounded-full flex items-center justify-center transition-colors" aria-label="Facebook">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== ANA MENÜ BARI ===== -->
  <div class="bg-white border-b border-koyu-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-20 md:h-24">
        <!-- Logo -->
        <a href="/" class="flex-shrink-0">
          <img src="/images/eymen-logo-yeni.png" alt="Eymen Reklam" class="h-14 md:h-[90px] w-auto" />
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-1">
          <!-- Hizmetlerimiz Dropdown -->
          <div class="relative group" id="hizmet-dropdown">
            <button class="flex items-center gap-1.5 px-5 py-2.5 text-[15px] font-semibold text-koyu-700 hover:text-eymen-600 transition-colors">
              Hizmetlerimiz
              <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <!-- Mega Menu -->
            <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-200 absolute top-full left-0 pt-2 z-50">
              <div class="bg-white rounded-2xl shadow-2xl border border-koyu-100 p-6 w-[700px]">
                <div class="grid grid-cols-3 gap-3">
                  {hizmetler.map(h => (
                    <a href={h.href} class="flex items-center gap-3 p-3 rounded-xl hover:bg-eymen-50 transition-colors group/item">
                      <span class="text-xl">{h.icon}</span>
                      <span class="text-sm font-medium text-koyu-700 group-hover/item:text-eymen-600 transition-colors">{h.label}</span>
                    </a>
                  ))}
                </div>
                <div class="mt-4 pt-4 border-t border-koyu-100">
                  <a href="/hizmetlerimiz" class="text-sm text-eymen-600 font-semibold hover:text-eymen-700 transition-colors">
                    Tüm Hizmetleri Görüntüle →
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Normal Links -->
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={[
                'px-5 py-2.5 text-[15px] font-semibold transition-colors',
                currentPath === link.href
                  ? 'text-eymen-600'
                  : 'text-koyu-700 hover:text-eymen-600'
              ]}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <!-- Sağ: Arama + CTA + Mobil -->
        <div class="flex items-center gap-3">
          <!-- Arama Kutusu Desktop -->
          <div class="hidden lg:flex items-center">
            <div class="relative">
              <input
                type="text"
                id="search-input"
                placeholder="Arama"
                class="w-40 xl:w-48 pl-4 pr-10 py-2 text-sm border-2 border-koyu-200 rounded-full focus:border-eymen-500 focus:outline-none transition-colors text-koyu-700 placeholder:text-koyu-400"
              />
              <button class="absolute right-3 top-1/2 -translate-y-1/2 text-koyu-400 hover:text-eymen-500 transition-colors" aria-label="Ara">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              </button>
            </div>
          </div>

          <!-- Kurumsal Teklif CTA Desktop -->
          <a
            href="/teklif-al"
            class="hidden lg:inline-flex items-center gap-2 bg-eymen-500 hover:bg-eymen-600 text-white px-6 py-3 rounded-lg text-sm font-bold transition-all hover:shadow-lg hover:shadow-eymen-500/20"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Kurumsal Teklif Al
          </a>

          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-lg text-koyu-600 hover:bg-koyu-50" aria-label="Menü">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="lg:hidden hidden border-t border-koyu-100 bg-white max-h-[80vh] overflow-y-auto">
      <div class="px-4 py-4 space-y-1">
        <!-- Mobil Telefon + E-posta -->
        <div class="flex flex-col gap-2 pb-3 mb-3 border-b border-koyu-100">
          <a href="tel:+902163790708" class="flex items-center gap-2 text-sm text-koyu-600">
            <svg class="w-4 h-4 text-eymen-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            (0216) 379 07 08
          </a>
          <a href="tel:+905356647752" class="flex items-center gap-2 text-sm font-semibold text-koyu-800">
            <svg class="w-4 h-4 text-eymen-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            0535 664 77 52
          </a>
        </div>

        <!-- Hizmetler Accordion -->
        <div>
          <button class="mobile-accordion-btn w-full flex items-center justify-between px-4 py-3 rounded-lg text-sm font-semibold text-koyu-700 hover:bg-koyu-50">
            Hizmetlerimiz
            <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="mobile-accordion-content hidden pl-4 space-y-1">
            {hizmetler.map(h => (
              <a href={h.href} class="flex items-center gap-2 px-4 py-2 text-sm text-koyu-500 hover:text-eymen-600 hover:bg-koyu-50 rounded-lg">
                <span>{h.icon}</span> {h.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Ürünler Accordion -->
        <div>
          <button class="mobile-accordion-btn w-full flex items-center justify-between px-4 py-3 rounded-lg text-sm font-semibold text-koyu-700 hover:bg-koyu-50">
            Ürünlerimiz
            <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="mobile-accordion-content hidden pl-4 space-y-1">
            {urunler.map(group => (
              <div class="mb-2">
                <p class="px-4 py-1 text-xs font-bold text-koyu-400 uppercase">{group.category}</p>
                {group.items.map(item => (
                  <a href={item.href} class="block px-4 py-2 text-sm text-koyu-500 hover:text-eymen-600 hover:bg-koyu-50 rounded-lg">
                    {item.label}
                  </a>
                ))}
              </div>
            ))}
          </div>
        </div>

        {navLinks.map(link => (
          <a href={link.href} class="block px-4 py-3 rounded-lg text-sm font-semibold text-koyu-700 hover:bg-koyu-50">
            {link.label}
          </a>
        ))}

        <a href="/teklif-al" class="block w-full text-center bg-eymen-500 hover:bg-eymen-600 text-white px-4 py-3 rounded-lg text-sm font-bold mt-3">
          Kurumsal Teklif Al
        </a>

        <!-- Mobil Sosyal Medya -->
        <div class="flex items-center justify-center gap-4 pt-3 border-t border-koyu-100 mt-3">
          <a href="https://www.instagram.com/eymenreklam/" target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-koyu-100 hover:bg-eymen-500 hover:text-white rounded-full flex items-center justify-center transition-colors text-koyu-500" aria-label="Instagram">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.youtube.com/@eymenreklam" target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-koyu-100 hover:bg-eymen-500 hover:text-white rounded-full flex items-center justify-center transition-colors text-koyu-500" aria-label="YouTube">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/eymenreklam/" target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-koyu-100 hover:bg-eymen-500 hover:text-white rounded-full flex items-center justify-center transition-colors text-koyu-500" aria-label="LinkedIn">
