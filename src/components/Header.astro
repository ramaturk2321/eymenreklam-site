---
const navLinks = [
  { href: '/', label: 'Ana Sayfa' },
  { href: '/hizmetlerimiz', label: 'Hizmetlerimiz' },
  { href: '/urunlerimiz', label: 'Ürünlerimiz' },
  { href: '/projelerimiz', label: 'Projelerimiz' },
  { href: '/hakkimizda', label: 'Hakkımızda' },
  { href: '/blog', label: 'Blog' },
  { href: '/iletisim', label: 'İletişim' },
];

const currentPath = Astro.url.pathname;
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-koyu-100 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-28 md:h-36">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img
          src="/images/eymen-logo.png"
          alt="Eymen Reklam"
          class="h-24 md:h-[150px] w-auto"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-2 text-sm font-medium rounded-lg transition-colors',
              currentPath === link.href
                ? 'text-eymen-600 bg-eymen-50'
                : 'text-koyu-600 hover:text-koyu-900 hover:bg-koyu-50'
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA + Mobile -->
      <div class="flex items-center gap-3">
        <!-- WhatsApp CTA Desktop -->
        <a
          href="https://wa.me/905356647752?text=Merhaba%2C%20teklif%20almak%20istiyorum."
          target="_blank"
          rel="noopener noreferrer"
          class="hidden md:inline-flex items-center gap-2 bg-eymen-500 hover:bg-eymen-600 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.75.75 0 00.913.913l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.43 0-4.678-.726-6.568-1.968l-.458-.307-2.973.997.997-2.973-.307-.458A9.953 9.953 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
          Teklif Al
        </a>

        <!-- Telefon Desktop -->
        <a
          href="tel:+902163790708"
          class="hidden lg:inline-flex items-center gap-2 text-koyu-600 hover:text-koyu-900 text-sm font-medium"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          (0216) 379 07 08
        </a>

        <!-- Dil Seçimi -->
        <div class="hidden md:flex items-center border-l border-koyu-200 pl-3 ml-1">
          <a href="/" class="px-2 py-1 text-xs font-bold text-eymen-600 bg-eymen-50 rounded" title="Türkçe">TR</a>
          <a href="/en" class="px-2 py-1 text-xs font-medium text-koyu-400 hover:text-koyu-700 rounded transition-colors" title="English">EN</a>
        </div>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg text-koyu-600 hover:bg-koyu-50"
          aria-label="Menü"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-koyu-100 bg-white">
    <div class="px-4 py-4 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'block px-4 py-3 rounded-lg text-sm font-medium transition-colors',
            currentPath === link.href
              ? 'text-eymen-600 bg-eymen-50'
              : 'text-koyu-600 hover:bg-koyu-50'
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://wa.me/905356647752?text=Merhaba%2C%20teklif%20almak%20istiyorum."
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full text-center bg-eymen-500 hover:bg-eymen-600 text-white px-4 py-3 rounded-lg text-sm font-semibold mt-3"
      >
        Ücretsiz Teklif Al
      </a>
      <!-- Mobil Dil Seçimi -->
      <div class="flex items-center gap-2 mt-3 px-4">
        <a href="/" class="px-3 py-2 text-xs font-bold text-eymen-600 bg-eymen-50 rounded">TR</a>
        <a href="/en" class="px-3 py-2 text-xs font-medium text-koyu-400 hover:text-koyu-700 bg-koyu-50 rounded transition-colors">EN</a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
