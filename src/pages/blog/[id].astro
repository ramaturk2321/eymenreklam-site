---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { company, contact, getWhatsAppUrl, whatsappIcon, socialLinks } from '../../lib/site-data';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// TOC: sadece h2 ve h3 başlıkları
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

// Diğer yazılar (3 adet, alt grid için)
const otherPosts = (await getCollection('blog'))
  .filter(p => p.id !== post.id && p.data.published)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

// Kategori → ilgili hizmet eşlemesi
const categoryServiceMap: Record<string, { title: string; href: string; icon: string }[]> = {
  'Tabela': [
    { title: 'Tabela İmalatı', href: '/hizmetlerimiz/tabela/', icon: '🏗️' },
    { title: 'Kutu Harf Tabela', href: '/urunlerimiz/kutu-harf-tabela/', icon: '🔤' },
    { title: 'Totem Tabela', href: '/urunlerimiz/totem-tabela/', icon: '🗼' },
  ],
  'UV Baskı': [
    { title: 'UV Baskı Hizmeti', href: '/hizmetlerimiz/uv-baski/', icon: '🖨️' },
    { title: 'UV Baskı Ürünleri', href: '/urunlerimiz/uv-baski/', icon: '🎨' },
  ],
  'Folyo & Giydirme': [
    { title: 'Folyo & Giydirme', href: '/hizmetlerimiz/folyo-giydirme/', icon: '🚗' },
    { title: 'Araç Kaplama', href: '/urunlerimiz/komple-arac-kaplama/', icon: '🚐' },
  ],
  'Dijital Baskı': [
    { title: 'Dijital Baskı', href: '/hizmetlerimiz/dijital-baski/', icon: '🖼️' },
  ],
};
const relatedServices = categoryServiceMap[post.data.category] || categoryServiceMap['Tabela'];

const dateFormatted = new Date(post.data.date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
const canonicalURL = new URL(`/blog/${post.id}/`, Astro.site);
const imageURL = new URL(post.data.image, Astro.site);

// Article Schema
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  image: imageURL.toString(),
  datePublished: post.data.date,
  author: {
    '@type': 'Organization',
    name: post.data.author,
    url: company.siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: company.name,
    logo: { '@type': 'ImageObject', url: new URL(company.logoPath, Astro.site).toString() },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
};

// Breadcrumb Schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: company.siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${company.siteUrl}/blog/` },
    { '@type': 'ListItem', position: 3, name: post.data.title },
  ],
};

// Paylaşım URL'leri
const shareUrl = canonicalURL.toString();
const shareTitle = encodeURIComponent(post.data.title);
const shareLinks = [
  { name: 'X', href: `https://twitter.com/intent/tweet?url=${encodeURIComponent(shareUrl)}&text=${shareTitle}`, icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
  { name: 'Facebook', href: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`, icon: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z' },
  { name: 'LinkedIn', href: `https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(shareUrl)}&title=${shareTitle}`, icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
  { name: 'WhatsApp', href: `https://wa.me/?text=${shareTitle}%20${encodeURIComponent(shareUrl)}`, icon: whatsappIcon },
];
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.image}>

  <!-- Article + Breadcrumb Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Breadcrumb -->
  <nav class="bg-koyu-50 border-b border-koyu-100 py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ol class="flex items-center gap-2 text-sm text-koyu-500">
        <li><a href="/" class="hover:text-eymen-600 transition-colors">Ana Sayfa</a></li>
        <li class="text-koyu-300">/</li>
        <li><a href="/blog/" class="hover:text-eymen-600 transition-colors">Blog</a></li>
        <li class="text-koyu-300">/</li>
        <li class="text-koyu-800 font-medium truncate">{post.data.title}</li>
      </ol>
    </div>
  </nav>

  <!-- Başlık Alanı (Tam genişlik) -->
  <header class="py-8 md:py-12 border-b border-koyu-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4">
          <span class="px-3 py-1 bg-eymen-50 text-eymen-700 text-xs font-bold rounded-full">{post.data.category}</span>
          <time class="text-sm text-koyu-400" datetime={post.data.date}>{dateFormatted}</time>
          <span class="text-sm text-koyu-400">— {post.data.author}</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-extrabold text-koyu-900 leading-tight">{post.data.title}</h1>
        <p class="text-koyu-500 mt-4 text-lg leading-relaxed">{post.data.excerpt}</p>
      </div>
    </div>
  </header>

  <!-- İki Kolonlu Ana Alan -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-10 lg:gap-14">

      <!-- SOL: Makale İçeriği -->
      <article>
        <!-- Kapak Görseli -->
        <div class="rounded-2xl overflow-hidden mb-10">
          <img src={post.data.image} alt={post.data.title} class="w-full aspect-[16/9] object-cover" />
        </div>

        <!-- TOC (Mobil - inline) -->
        {tocHeadings.length > 2 && (
          <nav class="lg:hidden bg-koyu-50 rounded-xl p-5 mb-8 border border-koyu-100">
            <h2 class="text-sm font-bold text-koyu-900 tracking-wider mb-3">BU YAZIDA</h2>
            <ul class="space-y-2">
              {tocHeadings.map(h => (
                <li class={h.depth === 3 ? 'pl-4' : ''}>
                  <a href={`#${h.slug}`} class="text-sm text-koyu-600 hover:text-eymen-600 transition-colors leading-snug block">
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )}

        <!-- İçerik -->
        <div class="prose prose-lg max-w-none prose-headings:text-koyu-900 prose-headings:font-bold prose-headings:scroll-mt-24 prose-p:text-koyu-600 prose-p:leading-relaxed prose-li:text-koyu-600 prose-strong:text-koyu-800 prose-a:text-eymen-600 prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl">
          <Content />
        </div>

        <!-- Paylaşım (Makale altı) -->
        <div class="mt-10 pt-8 border-t border-koyu-100">
          <div class="flex items-center gap-4">
            <span class="text-sm font-semibold text-koyu-700">Paylaş:</span>
            <div class="flex items-center gap-2">
              {shareLinks.map(s => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-9 h-9 bg-koyu-100 hover:bg-koyu-200 rounded-lg flex items-center justify-center text-koyu-500 hover:text-koyu-700 transition-all"
                  aria-label={`${s.name} ile paylaş`}
                >
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d={s.icon}/></svg>
                </a>
              ))}
            </div>
          </div>
        </div>
      </article>

      <!-- SAĞ: Sticky Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">

          <!-- TOC (Desktop - sidebar) -->
          {tocHeadings.length > 2 && (
            <nav class="bg-koyu-50 rounded-xl p-5 border border-koyu-100" id="sidebar-toc">
              <h3 class="text-sm font-bold text-koyu-900 tracking-wider mb-3">BU YAZIDA</h3>
              <ul class="space-y-2">
                {tocHeadings.map(h => (
                  <li class={h.depth === 3 ? 'pl-4' : ''}>
                    <a
                      href={`#${h.slug}`}
                      class="toc-link text-sm text-koyu-500 hover:text-eymen-600 transition-colors leading-snug block py-0.5"
                      data-slug={h.slug}
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )}

          <!-- CTA: Teklif Al -->
          <div class="bg-eymen-500 rounded-xl p-5 text-white">
            <h3 class="font-bold mb-2">Projeniz mi Var?</h3>
            <p class="text-sm text-eymen-100 mb-4 leading-relaxed">
              Ücretsiz keşif ve fiyat teklifi için hemen bize ulaşın.
            </p>
            <a
              href={getWhatsAppUrl()}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1fb855] text-white px-4 py-2.5 rounded-lg text-sm font-bold transition-all w-full mb-2"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d={whatsappIcon}/></svg>
              WhatsApp ile Yaz
            </a>
            <a
              href={contact.phoneHref}
              class="flex items-center justify-center gap-2 bg-white/15 hover:bg-white/25 text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition-all w-full"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              {contact.phone}
            </a>
          </div>

          <!-- İlgili Hizmetler -->
          <div class="bg-koyu-50 rounded-xl p-5 border border-koyu-100">
            <h3 class="text-sm font-bold text-koyu-900 tracking-wider mb-3">İLGİLİ HİZMETLER</h3>
            <div class="space-y-2">
              {relatedServices.map(s => (
                <a
                  href={s.href}
                  class="flex items-center gap-3 px-3 py-2.5 bg-white rounded-lg border border-koyu-100 hover:border-eymen-200 hover:shadow-sm transition-all group"
                >
                  <span class="text-lg">{s.icon}</span>
                  <span class="text-sm font-medium text-koyu-700 group-hover:text-eymen-600 transition-colors">{s.title}</span>
                  <svg class="w-4 h-4 text-koyu-300 ml-auto group-hover:text-eymen-500 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </a>
              ))}
            </div>
          </div>

          <!-- Diğer Yazılar (Sidebar) -->
          {otherPosts.length > 0 && (
            <div class="bg-koyu-50 rounded-xl p-5 border border-koyu-100">
              <h3 class="text-sm font-bold text-koyu-900 tracking-wider mb-3">DİĞER YAZILAR</h3>
              <div class="space-y-3">
                {otherPosts.slice(0, 2).map(p => (
                  <a href={`/blog/${p.id}/`} class="flex gap-3 group">
                    <img src={p.data.image} alt={p.data.title} class="w-16 h-16 rounded-lg object-cover shrink-0" loading="lazy" />
                    <div class="min-w-0">
                      <h4 class="text-sm font-semibold text-koyu-800 group-hover:text-eymen-600 transition-colors leading-snug line-clamp-2">{p.data.title}</h4>
                      <span class="text-xs text-koyu-400 mt-1 block">{new Date(p.data.date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

        </div>
      </aside>

    </div>
  </div>

  <!-- Alt CTA Banner (Tam Genişlik) -->
  <section class="bg-gradient-to-br from-eymen-500 to-eymen-700 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-3">Projeniz İçin Kurumsal Teklif Alın</h2>
      <p class="text-eymen-100 mb-6">Uzman ekibimiz projenizi inceler, 3D ön izleme hazırlar ve detaylı fiyat teklifi sunar.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/teklif-al" class="inline-flex items-center justify-center gap-2 bg-white text-eymen-600 hover:bg-koyu-50 px-8 py-3.5 rounded-xl text-base font-bold transition-all">
          Kurumsal Teklif Formu
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href={contact.phoneHref} class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white/60 text-white px-8 py-3.5 rounded-xl text-base font-semibold transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {contact.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- Alt: Diğer Yazılar Grid (Tam Genişlik, 3'lü) -->
  {otherPosts.length > 0 && (
    <section class="bg-koyu-50 py-12 border-t border-koyu-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-extrabold text-koyu-900 mb-8 text-center">Bunları da Okuyun</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {otherPosts.map(p => (
            <a href={`/blog/${p.id}/`} class="group bg-white rounded-2xl border border-koyu-100 overflow-hidden hover:shadow-xl hover:border-eymen-200 transition-all duration-300 hover:-translate-y-1">
              <div class="aspect-[16/9] overflow-hidden">
                <img src={p.data.image} alt={p.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
              <div class="p-5">
                <div class="flex items-center gap-2 mb-2">
                  <span class="px-2.5 py-0.5 bg-eymen-50 text-eymen-700 text-xs font-semibold rounded-full">{p.data.category}</span>
                  <span class="text-xs text-koyu-400">{new Date(p.data.date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                </div>
                <h3 class="font-bold text-koyu-900 group-hover:text-eymen-600 transition-colors leading-snug">{p.data.title}</h3>
                <p class="text-sm text-koyu-500 mt-2 leading-relaxed line-clamp-2">{p.data.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>

<!-- TOC Active Highlight Script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tocLinks = document.querySelectorAll('.toc-link');
    if (tocLinks.length === 0) return;

    const headingEls = Array.from(tocLinks).map(link => {
      const slug = (link as HTMLElement).dataset.slug;
      return slug ? document.getElementById(slug) : null;
    }).filter(Boolean) as HTMLElement[];

    if (headingEls.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(l => l.classList.remove('text-eymen-600', 'font-semibold'));
            const activeLink = document.querySelector(`.toc-link[data-slug="${entry.target.id}"]`);
            if (activeLink) {
              activeLink.classList.add('text-eymen-600', 'font-semibold');
            }
          }
        });
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
    );

    headingEls.forEach(el => observer.observe(el));
  });
</script>
