---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.published)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Tabela ve Reklam Sektörü Rehberleri" description="Tabela imalatı, UV baskı, dijital baskı ve araç giydirme hakkında teknik rehberler. Pendik İstanbul'dan Eymen Reklam uzman içerikleri.">

  <!-- Hero -->
  <section class="bg-koyu-900 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-eymen-400 text-sm font-semibold tracking-wider mb-3">BİLGİ BANKASI</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Tabela ve Reklam Rehberleri</h1>
      <p class="text-koyu-400 text-lg max-w-2xl mx-auto">
        Tabela imalatı, UV baskı ve reklam sektörü hakkında teknik rehberler. Pendik İstanbul'dan uzman içerikler.
      </p>
    </div>
  </section>

  <!-- Blog Listesi -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {posts.map(post => (
          <article class="group bg-white rounded-2xl border border-koyu-100 overflow-hidden hover:shadow-lg hover:border-eymen-200 transition-all duration-300">
            <a href={`/blog/${post.id}/`}>
              <div class="aspect-[16/9] overflow-hidden">
                <img src={post.data.image} alt={post.data.title} width="600" height="400" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
            </a>
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="px-2.5 py-0.5 bg-eymen-50 text-eymen-700 text-xs font-semibold rounded-full">{post.data.category}</span>
                <span class="text-xs text-koyu-400">{new Date(post.data.date).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
              </div>
              <h2 class="text-lg font-bold text-koyu-900 mb-2 group-hover:text-eymen-600 transition-colors leading-snug">
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h2>
              <p class="text-sm text-koyu-500 leading-relaxed line-clamp-3">{post.data.excerpt}</p>
              <div class="mt-4">
                <a href={`/blog/${post.id}/`} class="text-sm text-eymen-600 font-semibold hover:text-eymen-700 transition-colors inline-flex items-center gap-1">
                  Devamını Oku
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
