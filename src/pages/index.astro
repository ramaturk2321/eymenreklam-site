  {
    id: 'kurumsal',
    label: 'Kurumsal Hizmetler',
    products: [
      { img: '/images/urunler/hakmar-avm-1.jpg', title: 'Hakmar AVM', href: '/urunlerimiz/hakmar-avm' },
      { img: '/images/urunler/eve-magazasi-1.jpg', title: 'Eve Mağazası', href: '/urunlerimiz/eve-magazasi' },
