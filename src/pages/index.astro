const stats = [
  { number: '25+', label: 'Yıllık Tecrübe', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
  { number: '10.000+', label: 'Tamamlanan Proje', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
  { number: '2.500m²', label: 'Üretim Tesisi', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  { number: '500+', label: 'Kurumsal Müşteri', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
];

const projeler = (await getCollection('projeler'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 6);

const testimonials = [
  { text: 'Mağazamızın tüm tabela ve cephe giydirme işlerini Eymen Reklam ile yaptırdık. Kaliteli malzeme ve profesyonel montaj.', author: 'Mehmet K.', role: 'Mağaza Sahibi' },
  { text: 'Filomuzun araç giydirme işleri için 3 yıldır Eymen Reklam ile çalışıyoruz. Hızlı teslimat ve uygun fiyat.', author: 'Ayşe T.', role: 'Lojistik Müdürü' },
  { text: 'UV baskı kalitesi gerçekten üst seviye. Showroom tasarımımız için mükemmel sonuçlar aldık.', author: 'Ali R.', role: 'İç Mimar' },
];

const partners = [
  { name: 'Hakmar Express', logo: '/images/markalar/hakmar-express.png' },
  { name: 'Hakmar Şirketler Grubu', logo: '/images/markalar/hakmar.png' },
  { name: 'Lina', logo: '/images/markalar/lina.png' },
  { name: 'g2m', logo: '/images/markalar/g2m.png' },
  { name: '2Plan', logo: '/images/markalar/2plan.png' },
  { name: 'Bizim Toptan Market', logo: '/images/markalar/bizim.png' },
];
---

<BaseLayout title="Ana Sayfa" description="Eymen Reklam — 25 yıldır Pendik İstanbul'da tabela imalatı, UV baskı, araç giydirme ve dijital baskı hizmetleri. Ücretsiz keşif ve teklif alın.">

  <!-- ========== HERO SLIDER ========== -->
  <section class="relative bg-koyu-900 overflow-hidden" id="hero">
    <div class="relative h-[500px] md:h-[600px] lg:h-[700px]">
      <img src="/images/yenifabrika-opt.webp" alt="Eymen Reklam Üretim Tesisi" class="w-full h-full object-cover" width="1920" height="742" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-koyu-900/90 via-koyu-900/60 to-koyu-900/30"></div>
      <div class="absolute inset-0 flex items-center">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
          <div class="max-w-2xl">
            <p class="text-eymen-400 text-sm md:text-base font-semibold uppercase tracking-widest mb-4">1999'dan Beri</p>
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white leading-tight mb-6">
              Reklam Hayallerinizi<br/>
              <span class="text-eymen-500">Gerçeğe Dönüştürüyoruz</span>
            </h1>
            <p class="text-lg md:text-xl text-koyu-300 mb-8 max-w-xl">
              Kurumsal tabela imalatı, UV baskı ve dijital baskı çözümleri. İstanbul Pendik'ten Türkiye'ye hizmet veriyoruz.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="https://wa.me/905356647752?text=Merhaba%2C%20teklif%20almak%20istiyorum." target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 bg-eymen-500 hover:bg-eymen-600 text-white px-8 py-4 rounded-lg text-base font-bold transition-all hover:shadow-xl hover:shadow-eymen-500/30">
                Ücretsiz Teklif Alın
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
              <a href="/hizmetlerimiz" class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white text-white px-8 py-4 rounded-lg text-base font-semibold transition-all hover:bg-white/10">
                Hizmetlerimiz
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== KATEGORİ SEKMELİ ÜRÜN GALERİSİ ========== -->
  <section class="bg-white" id="urunler">
    <!-- Dark Tab Bar -->
    <div class="sticky top-20 lg:top-[136px] z-30 bg-koyu-600 shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex overflow-x-auto scrollbar-hide" id="category-tabs">
          {categories.map((cat, i) => (
            <button
              class:list={[
                'category-tab whitespace-nowrap px-5 lg:px-6 py-4 text-sm font-semibold transition-all flex-shrink-0 relative',
                i === 0
                  ? 'bg-eymen-500 text-white font-extrabold'
                  : 'text-koyu-300 hover:text-white hover:bg-koyu-500'
              ]}
              data-category={cat.id}
            >
              {cat.label}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Ürün Grid -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
      {categories.map((cat, i) => (
        <div
          class:list={[
            'category-panel grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5',
            i === 0 ? '' : 'hidden'
          ]}
          data-panel={cat.id}
        >
          {cat.products.map(product => (
            <a href={product.href} class="group block">
              <div class="relative rounded-xl overflow-hidden bg-koyu-100 aspect-[4/3]">
                <img
                  src={product.img}
                  alt={product.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
                <div class="absolute inset-0 bg-koyu-900/0 group-hover:bg-koyu-900/30 transition-all duration-300 flex items-center justify-center">
                  <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 w-10 h-10 bg-eymen-500 rounded-full flex items-center justify-center">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                  </span>
                </div>
              </div>
              <h3 class="mt-3 text-sm font-semibold text-koyu-800 group-hover:text-eymen-600 transition-colors">{product.title}</h3>
            </a>
          ))}
        </div>
      ))}

      <!-- Pagination dots (dekoratif) -->
      <div class="flex items-center gap-2 mt-8">
        <div class="w-3 h-3 rounded-full bg-eymen-500"></div>
        <div class="w-3 h-3 rounded-full bg-koyu-200"></div>
      </div>
    </div>
  </section>

  <!-- ========== İSTATİSTİKLER — PARALLAX ========== -->
  <section class="relative py-20 md:py-28 bg-fixed bg-cover bg-center" style="background-image: url('/images/cephe-giydirme.jpg');">
    <div class="absolute inset-0 bg-koyu-900/85"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
        {stats.map(stat => (
          <div class="text-center group">
            <div class="w-16 h-16 bg-eymen-500/20 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:bg-eymen-500 transition-colors duration-300">
              <svg class="w-8 h-8 text-eymen-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={stat.icon}/>
              </svg>
            </div>
            <div class="text-3xl md:text-5xl font-extrabold text-white mb-2">{stat.number}</div>
            <div class="text-sm text-koyu-300 font-medium uppercase tracking-wider">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== PROJELER ========== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <div class="inline-flex items-center gap-2 justify-center mb-4">
          <div class="w-10 h-[2px] bg-eymen-500"></div>
          <span class="text-eymen-500 text-sm font-bold uppercase tracking-widest">Projelerimiz</span>
          <div class="w-10 h-[2px] bg-eymen-500"></div>
        </div>
        <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-900">Son Çalışmalarımız</h2>
        <p class="text-koyu-500 mt-4">Her projemizde kaliteyi ve müşteri memnuniyetini ön planda tutuyoruz.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {projeler.map(project => (
          <a href={`/projelerimiz/${project.id}/`} class="group relative rounded-2xl overflow-hidden h-72 block">
            <img src={project.data.image} alt={project.data.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-koyu-900/90 via-koyu-900/20 to-transparent opacity-60 group-hover:opacity-100 transition-opacity duration-300"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
              <span class="text-eymen-400 text-xs font-bold uppercase tracking-wider">{project.data.categories[0]}</span>
              <h3 class="text-white text-lg font-bold mt-1">{project.data.title}</h3>
            </div>
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-all duration-300 scale-50 group-hover:scale-100">
              <div class="w-14 h-14 bg-eymen-500 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/projelerimiz" class="inline-flex items-center gap-2 border-2 border-eymen-500 text-eymen-600 hover:bg-eymen-500 hover:text-white px-8 py-3.5 rounded-lg font-semibold transition-all">
          Tüm Projeleri Görüntüle
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== MÜŞTERİ YORUMLARI ========== -->
  <section class="py-20 md:py-28 bg-koyu-50 relative overflow-hidden">
    <div class="absolute -bottom-10 -right-10 w-72 h-72 border-2 border-koyu-200 rotate-45 opacity-30"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <div class="inline-flex items-center gap-2 justify-center mb-4">
          <div class="w-10 h-[2px] bg-eymen-500"></div>
          <span class="text-eymen-500 text-sm font-bold uppercase tracking-widest">Müşteri Yorumları</span>
          <div class="w-10 h-[2px] bg-eymen-500"></div>
        </div>
        <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-900">Müşterilerimiz Ne Diyor?</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map(t => (
          <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-shadow relative">
            <div class="absolute -top-4 left-8 w-10 h-10 bg-eymen-500 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/></svg>
            </div>
            <p class="text-koyu-600 leading-relaxed mt-4 mb-6 italic">"{t.text}"</p>
            <div class="flex items-center gap-3 border-t border-koyu-100 pt-4">
              <div class="w-10 h-10 bg-eymen-100 rounded-full flex items-center justify-center">
                <span class="text-eymen-600 font-bold text-sm">{t.author[0]}</span>
              </div>
              <div>
                <div class="font-bold text-koyu-900 text-sm">{t.author}</div>
                <div class="text-xs text-koyu-600">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== İŞ ORTAKLARI ========== -->
  <section class="py-14 bg-white border-y border-koyu-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
