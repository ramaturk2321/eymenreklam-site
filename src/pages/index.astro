<style>
  .slide-up {
    opacity: 0;
    transform: translateY(30px);
    animation: slideUp 0.7s ease-out forwards;
  }
  .slide-delay-1 { animation-delay: 0.15s; }
  .slide-delay-2 { animation-delay: 0.3s; }
  .slide-delay-3 { animation-delay: 0.45s; }

  @keyframes slideUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Scrollbar gizle */
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  // Category Tabs
  const tabs = document.querySelectorAll('.category-tab');
  const panels = document.querySelectorAll('.category-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const category = (tab as HTMLElement).dataset.category;

      // Tüm sekmeleri pasif yap
      tabs.forEach(t => {
        t.className = 'category-tab whitespace-nowrap px-5 lg:px-6 py-4 text-sm font-semibold transition-all flex-shrink-0 relative text-koyu-300 hover:text-white hover:bg-koyu-500';
      });
      // Aktif sekme — bold + turuncu arka plan
      tab.className = 'category-tab whitespace-nowrap px-5 lg:px-6 py-4 text-sm font-extrabold transition-all flex-shrink-0 relative bg-eymen-500 text-white';

      // Tüm panelleri gizle
      panels.forEach(p => p.classList.add('hidden'));
      // Aktif paneli göster
      document.querySelector(`[data-panel="${category}"]`)?.classList.remove('hidden');
    });
  });
</script>
