---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  { icon: '🔤', title: 'Kutu Harf Tabela', desc: 'LED aydınlatmalı 3D kutu harf üretimi. Gündüz ve gece etkili marka görünürlüğü.' },
  { icon: '🖨️', title: 'UV Baskı', desc: 'Ahşap, cam, metal ve plastik yüzeylere yüksek çözünürlüklü doğrudan baskı.' },
  { icon: '🚗', title: 'Araç Giydirme', desc: 'Komple ve kısmi araç kaplama. Filo branding ile hareketli reklam çözümleri.' },
  { icon: '📐', title: 'Tabela İmalatı', desc: 'Totem, çatı, cephe ve yönlendirme tabelaları. Anahtar teslim üretim ve montaj.' },
  { icon: '🏢', title: 'Cephe Giydirme', desc: 'Folyo, kompozit panel ve dijital baskı ile bina cephesi kaplama ve yenileme.' },
  { icon: '🖼️', title: 'Dijital Baskı', desc: 'Branda, vinil, mesh ve kumaş baskı. İç ve dış mekan reklam çözümleri.' },
];

const stats = [
  { number: '25+', label: 'Yıllık Tecrübe' },
  { number: '10.000+', label: 'Tamamlanan Proje' },
  { number: '2.500m²', label: 'Üretim Tesisi' },
  { number: '500+', label: 'Kurumsal Müşteri' },
];

const usps = [
  { icon: '🎯', title: 'Teknik Hassasiyet', desc: 'CNC kesim, lazer ölçüm ve kalibre renk yönetimi ile kusursuz sonuçlar.' },
  { icon: '⏱️', title: 'Zamanında Teslimat', desc: 'Endüstriyel proje yönetimi protokolleriyle her teslim tarihine uyum.' },
  { icon: '🤝', title: 'Kurumsal Uzmanlık', desc: '25 yıldır kurumsal müşterilere özel çözümler üreten deneyimli ekip.' },
];
---

<BaseLayout title="Ana Sayfa" description="Eymen Reklam — 25 yıldır Pendik İstanbul'da tabela imalatı, UV baskı, araç giydirme ve dijital baskı hizmetleri. Ücretsiz keşif ve teklif alın.">

  <!-- ========== HERO ========== -->
  <section class="relative bg-koyu-900 overflow-hidden">
    <!-- Arka plan görsel -->
    <div class="absolute inset-0">
      <img
        src="/images/fabrika.png"
        alt="Eymen Reklam Üretim Tesisi"
        class="w-full h-full object-cover opacity-60"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-koyu-900/80 via-koyu-900/50 to-transparent"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36 lg:py-44">
      <div class="max-w-2xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-eymen-500/10 border border-eymen-500/20 rounded-full px-4 py-1.5 mb-6 fade-up">
          <span class="w-2 h-2 bg-eymen-500 rounded-full"></span>
          <span class="text-eymen-400 text-xs font-semibold uppercase tracking-wider">1999'dan Beri</span>
        </div>

        <!-- Başlık -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6 fade-up fade-up-delay-1">
          25 Yıllık Üretim
          <span class="text-eymen-500 block">Tecrübesi</span>
        </h1>

        <!-- Alt metin -->
        <p class="text-lg md:text-xl text-koyu-300 leading-relaxed mb-8 max-w-xl fade-up fade-up-delay-2">
          Kurumsal tabela imalatı, UV baskı ve dijital baskı çözümleri.
          İstanbul Pendik'ten Türkiye'ye hizmet veriyoruz.
        </p>

        <!-- CTA Butonlar -->
        <div class="flex flex-col sm:flex-row gap-4 fade-up fade-up-delay-3">
          <a
            href="https://wa.me/905356647752?text=Merhaba%2C%20teklif%20almak%20istiyorum."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-eymen-500 hover:bg-eymen-600 text-white px-8 py-4 rounded-xl text-base font-semibold transition-all hover:shadow-lg hover:shadow-eymen-500/25"
          >
            Ücretsiz Teklif Alın
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a
            href="/hizmetlerimiz"
            class="inline-flex items-center justify-center gap-2 border border-koyu-600 hover:border-koyu-400 text-koyu-200 hover:text-white px-8 py-4 rounded-xl text-base font-semibold transition-all"
          >
            Hizmetlerimizi İnceleyin
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== İSTATİSTİKLER ========== -->
  <section class="bg-white border-b border-koyu-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map(stat => (
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-extrabold text-eymen-500">{stat.number}</div>
            <div class="text-sm text-koyu-500 mt-1 font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== HİZMETLER — BENTO GRID ========== -->
  <section class="bg-koyu-50 py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Bölüm Başlığı -->
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-eymen-500 text-sm font-semibold uppercase tracking-wider mb-3">Uzmanlık Alanlarımız</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-900">Profesyonel Reklam Çözümleri</h2>
        <p class="text-koyu-500 mt-4">Her ölçekte projede 25 yıllık üretim deneyimini müşterilerimize sunuyoruz.</p>
      </div>

      <!-- Bento Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map((service, i) => (
          <a
            href="/hizmetlerimiz"
            class="group bg-white rounded-2xl p-7 border border-koyu-100 hover:border-eymen-200 hover:shadow-lg hover:shadow-eymen-500/5 transition-all duration-300 hover:-translate-y-1"
          >
            <span class="text-3xl block mb-4">{service.icon}</span>
            <h3 class="text-lg font-bold text-koyu-900 mb-2 group-hover:text-eymen-600 transition-colors">{service.title}</h3>
            <p class="text-sm text-koyu-500 leading-relaxed">{service.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== FABRİKA / HAKKIMIZDA ========== -->
  <section class="bg-white py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Görsel -->
        <div class="relative">
          <img
            src="/images/fabrika.png"
            alt="Eymen Reklam Pendik Üretim Tesisi"
            class="rounded-2xl shadow-xl w-full"
          />
          <div class="absolute -bottom-5 -right-5 bg-eymen-500 text-white rounded-2xl px-6 py-4 shadow-lg">
            <div class="text-3xl font-extrabold">25</div>
            <div class="text-xs font-semibold uppercase tracking-wider">Yıllık Güven</div>
          </div>
        </div>

        <!-- İçerik -->
        <div>
          <p class="text-eymen-500 text-sm font-semibold uppercase tracking-wider mb-3">Neden Eymen Reklam?</p>
          <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-900 mb-6">
            Pendik'te Stratejik Üretim Merkezi
          </h2>
          <p class="text-koyu-600 leading-relaxed mb-6">
            2.500m² üretim tesisimiz, son teknoloji SwissQprint UV baskı makineleri ve CNC işleme merkezleri ile
            yüksek hacimli kurumsal siparişleri hassasiyetle tamamlıyoruz.
          </p>
          <p class="text-koyu-600 leading-relaxed mb-8">
            1999'dan bu yana 500'ün üzerinde kurumsal müşteriyle çalışarak 10.000'den fazla projeyi
            başarıyla teslim ettik. Keşiften montaja kadar tüm süreçleri kendi bünyemizde yürütüyoruz.
          </p>
          <a
            href="/hakkimizda"
            class="inline-flex items-center gap-2 text-eymen-600 hover:text-eymen-700 font-semibold transition-colors"
          >
            Daha fazla bilgi
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== USP / NEDEN BİZ ========== -->
  <section class="bg-koyu-900 py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Hassasiyet Bizim Standardımız</h2>
        <div class="w-12 h-1 bg-eymen-500 mx-auto mt-4"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {usps.map(usp => (
          <div class="text-center">
            <span class="text-4xl block mb-4">{usp.icon}</span>
            <h3 class="text-lg font-bold text-white mb-3">{usp.title}</h3>
            <p class="text-sm text-koyu-400 leading-relaxed">{usp.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="bg-gradient-to-br from-eymen-500 to-eymen-700 py-20 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
        Markanızın Fiziksel Varlığını Tanımlayalım
      </h2>
      <p class="text-eymen-100 text-lg mb-8 max-w-2xl mx-auto">
        Tabela, UV baskı ve kurumsal reklam çözümlerinde ücretsiz keşif ve teklif alın.
        Profesyonel ekibimiz 24 saat içinde dönüş yapar.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://wa.me/905356647752?text=Merhaba%2C%20teklif%20almak%20istiyorum."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-white text-eymen-600 hover:bg-koyu-50 px-8 py-4 rounded-xl text-base font-bold transition-all hover:shadow-lg"
        >
          Ücretsiz Keşif ve Teklif Alın
        </a>
        <a
          href="tel:+902163790708"
          class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white/60 text-white px-8 py-4 rounded-xl text-base font-semibold transition-all"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          (0216) 379 07 08
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
