  features: [
    { icon: '🚗', title: 'Araç Giydirmesi (Full Wrap)', desc: 'Araç tuğlasının tamamına folyo kaplanması. Markalaştırma, reklam, koruma amaçlı çalışmalar.' },
    { icon: '🏢', title: 'Bina Cephesi & Dekor', desc: 'Geniş cephe kaplama, pencere dekorasyonu, iç mekan duvar folyo uygulamaları.' },
    { icon: '🪟', title: 'Cam Folyo Uygulamaları', desc: 'One-way-vision, dekoratif desenleme, mat cam, ısı kontrol filmaları.' },
    { icon: '✨', title: 'Premium Folyo Malzemeleri', desc: 'Avery Dennison ve 3M kalitesi folyo. 5-7 yıl dış mekan garantili, UV dirençli, dayanıklı.' },
    { icon: '👨‍🔧', title: 'Profesyonel Kurulum', desc: 'Eğitimli ve deneyimli montaj ekibi. Hava kabarcığı ve buruşuk olmayan tam uyum sağlanır.' },
    { icon: '🔧', title: 'Onarım & Bakım', desc: 'Hasar gören folyo kısmi değişim ve bakım hizmetleri sunuyoruz.' },
  ],
  products: [
    { title: 'Araç Giydirmesi (Full Wrap)', desc: 'Araç dış cephesinin tamamına kurumsal markalama veya reklam folyo uygulaması. Koruma ve görünürlük.', image: '/images/arac-giydirme.jpg', href: '/urunlerimiz/arac-giydirmesi' },
    { title: 'Kısmi Araç Kaportası', desc: 'Araçın yan kapı, çatı, ön arka bölümlerine seçmeli folyo uygulaması. Ekonomik reklam çözümü.', image: '/images/arac-giydirme.jpg', href: '/urunlerimiz/kismi-kaporta' },
    { title: 'Bina Cephesi Kaplaması', desc: 'Büyük ölçekli bina cephesi giydirmesi. Depo, şantiye, fabrika cepheleri reklam ve dekorasyonla.', image: '/images/cephe-giydirme.jpg', href: '/urunlerimiz/bina-giydirmesi' },
    { title: 'One-Way-Vision Cam Folyo', desc: 'Camdan dışarı bakılabiliyor, dışarıdan içeri görülmüyor. Gizlilik ve markalama için ideal.', image: '/images/cephe-giydirme.jpg', href: '/urunlerimiz/one-way-vision' },
    { title: 'Dekoratif Cam Folyo', desc: 'Pencere, kapı ve ofis bölmelerine dekoratif desen ve logo uygulaması.', image: '/images/cephe-giydirme.jpg', href: '/urunlerimiz/dekoratif-folyo' },
    { title: 'İç Mekan Duvar Folyo', desc: 'Ofis ve showroom duvarlarına marka logo, resim ve desen baskılı folyo uygulaması.', image: '/images/cephe-giydirme.jpg', href: '/urunlerimiz/duvar-folyo' },
  ],
  process: [
    { step: '01', title: 'Ölçüm & Tasarım', desc: 'Harita, fotoğraf ve ölçüm alınarak tasarım hazırlanır. Kurumsal id, logo, renkler belirlenir.' },
