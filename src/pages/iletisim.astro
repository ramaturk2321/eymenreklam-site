---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contact } from '../lib/site-data';
---

<BaseLayout title="İletişim — Eymen Reklam Pendik İstanbul" description="Eymen Reklam ile iletişime geçin. Pendik İstanbul'da tabela imalatı, dijital baskı ve reklam çözümleri için ücretsiz keşif ve teklif alın.">

  <!-- Hero -->
  <section class="bg-koyu-900 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-eymen-400 text-sm font-semibold uppercase tracking-wider mb-3">Bize Ulaşın</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">İletişim</h1>
      <p class="text-koyu-400 text-lg max-w-2xl mx-auto">
        Projeniz hakkında konuşmak, ücretsiz keşif ve teklif almak için bize ulaşın.
      </p>
    </div>
  </section>

  <!-- İletişim -->
  <section class="py-16 md:py-24 bg-koyu-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">

        <!-- Sol: İletişim Bilgileri -->
        <div>
          <h2 class="text-2xl font-extrabold text-koyu-900 mb-8">İletişim Bilgilerimiz</h2>

          <div class="space-y-6">
            <!-- Adres -->
            <div class="flex items-start gap-4 p-5 bg-white rounded-xl">
              <div class="w-10 h-10 bg-eymen-100 text-eymen-600 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <h4 class="font-semibold text-koyu-900 mb-1">Adres</h4>
                <p class="text-sm text-koyu-600">Eymen Reklam Matbaa Tanıtım İnşaat Ltd. Şti.</p>
                <p class="text-sm text-koyu-600">Esenler Mah. Çevre Sk. No: 7</p>
                <p class="text-sm text-koyu-600">Pendik / İstanbul</p>
              </div>
            </div>

            <!-- Telefon -->
            <div class="flex items-start gap-4 p-5 bg-white rounded-xl">
              <div class="w-10 h-10 bg-eymen-100 text-eymen-600 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <h4 class="font-semibold text-koyu-900 mb-1">Telefon</h4>
                <a href={contact.phoneHref} class="text-sm text-koyu-600 hover:text-eymen-600 transition-colors block">Sabit: {contact.phone}</a>
                <a href={contact.mobileHref} class="text-sm text-koyu-600 hover:text-eymen-600 transition-colors block">Cep: {contact.mobile}</a>
              </div>
            </div>

            <!-- WhatsApp -->
            <div class="flex items-start gap-4 p-5 bg-white rounded-xl">
              <div class="w-10 h-10 bg-green-100 text-green-600 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.75.75 0 00.913.913l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
              </div>
              <div>
                <h4 class="font-semibold text-koyu-900 mb-1">WhatsApp</h4>
                <a
                  href="https://wa.me/905356647752?text=Merhaba%2C%20teklif%20almak%20istiyorum."
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-green-600 hover:text-green-700 font-medium transition-colors"
                >
                  WhatsApp ile yazın →
                </a>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4 p-5 bg-white rounded-xl">
              <div class="w-10 h-10 bg-eymen-100 text-eymen-600 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <h4 class="font-semibold text-koyu-900 mb-1">E-posta</h4>
                <a href={contact.emailHref} class="text-sm text-koyu-600 hover:text-eymen-600 transition-colors block">{contact.email}</a>
              </div>
            </div>

            <!-- Çalışma Saatleri -->
            <div class="flex items-start gap-4 p-5 bg-white rounded-xl">
              <div class="w-10 h-10 bg-eymen-100 text-eymen-600 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <h4 class="font-semibold text-koyu-900 mb-1">Çalışma Saatleri</h4>
                <p class="text-sm text-koyu-600">Pazartesi - Cuma: 09:00 - 18:30</p>
                <p class="text-sm text-koyu-400">Cumartesi - Pazar: Kapalı</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Sağ: İletişim Formu -->
        <div>
          <h2 class="text-2xl font-extrabold text-koyu-900 mb-8">Teklif Talep Formu</h2>

          <form class="space-y-5" id="iletisim-form">
            <input type="hidden" name="access_key" value="6eef2241-f453-4dd5-8881-0566fadae644" />
            <input type="hidden" name="subject" value="Eymen Reklam — Yeni Teklif Talebi" />
            <input type="hidden" name="from_name" value="Eymen Reklam Website" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
            <div id="form-success" class="hidden bg-green-50 border border-green-200 rounded-xl p-6 text-center">
              <svg class="w-12 h-12 text-green-500 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <p class="text-lg font-semibold text-green-800">Mesajiniz basariyla gonderildi!</p>
              <p class="text-sm text-green-600 mt-1">En kisa surede size donecegiz.</p>
            </div>
            <div id="form-error" class="hidden bg-red-50 border border-red-200 rounded-xl p-4 text-center">
              <p class="text-sm font-medium text-red-700">Bir hata olustu. Lutfen tekrar deneyin veya bizi arayin.</p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-koyu-700 mb-1.5">Ad Soyad</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-3 border border-koyu-200 rounded-xl text-sm focus:ring-2 focus:ring-eymen-500 focus:border-eymen-500 outline-none transition-colors" />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-koyu-700 mb-1.5">Firma Adı</label>
                <input type="text" id="company" name="company"
                  class="w-full px-4 py-3 border border-koyu-200 rounded-xl text-sm focus:ring-2 focus:ring-eymen-500 focus:border-eymen-500 outline-none transition-colors" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="phone" class="block text-sm font-medium text-koyu-700 mb-1.5">Telefon</label>
                <input type="tel" id="phone" name="phone" required
                  class="w-full px-4 py-3 border border-koyu-200 rounded-xl text-sm focus:ring-2 focus:ring-eymen-500 focus:border-eymen-500 outline-none transition-colors" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-koyu-700 mb-1.5">E-posta</label>
                <input type="email" id="email" name="email"
                  class="w-full px-4 py-3 border border-koyu-200 rounded-xl text-sm focus:ring-2 focus:ring-eymen-500 focus:border-eymen-500 outline-none transition-colors" />
              </div>
            </div>

            <div>
              <label for="service" class="block text-sm font-medium text-koyu-700 mb-1.5">Hizmet Türü</label>
              <select id="service" name="service"
                class="w-full px-4 py-3 border border-koyu-200 rounded-xl text-sm focus:ring-2 focus:ring-eymen-500 focus:border-eymen-500 outline-none transition-colors bg-white">
                <option value="">Seçiniz</option>
                <option value="tabela">Tabela İmalatı</option>
                <option value="kutu-harf">Kutu Harf Tabela</option>
                <option value="uv-baski">UV Baskı</option>
                <option value="arac-giydirme">Araç Giydirme</option>
                <option value="dijital-baski">Dijital Baskı</option>
                <option value="cephe-giydirme">Cephe Giydirme</option>
                <option value="folyo">Folyo & Giydirme</option>
                <option value="diger">Diğer</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-koyu-700 mb-1.5">Proje Detayı</label>
              <textarea id="message" name="message" rows="4" required
                class="w-full px-4 py-3 border border-koyu-200 rounded-xl text-sm focus:ring-2 focus:ring-eymen-500 focus:border-eymen-500 outline-none transition-colors resize-none"
                placeholder="Projeniz hakkında kısa bilgi veriniz (boyut, malzeme, adet vb.)"></textarea>
            </div>

            <button
              type="submit"
              id="form-submit-btn"
              class="w-full bg-eymen-500 hover:bg-eymen-600 text-white py-4 rounded-xl text-base font-semibold transition-colors"
            >
              Teklif Talebi Gönder
            </button>
          </form>

          <script>
            const form = document.getElementById('iletisim-form');
            const btn = document.getElementById('form-submit-btn');
            const successDiv = document.getElementById('form-success');
            const errorDiv = document.getElementById('form-error');

            form.addEventListener('submit', async (e) => {
              e.preventDefault();
              btn.disabled = true;
              btn.textContent = 'Gonderiliyor...';
              successDiv.classList.add('hidden');
              errorDiv.classList.add('hidden');

              try {
                const res = await fetch('https://api.web3forms.com/submit', {
                  method: 'POST',
                  body: new FormData(form)
                });
                const data = await res.json();
                if (data.success) {
                  form.querySelectorAll('input:not([type=hidden]):not([type=checkbox]), textarea, select').forEach(el => el.value = '');
                  successDiv.classList.remove('hidden');
                  successDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
                } else {
                  errorDiv.classList.remove('hidden');
                }
              } catch (err) {
                errorDiv.classList.remove('hidden');
              }
              btn.disabled = false;
              btn.textContent = 'Teklif Talebi Gönder';
            });
          </script>
        </div>
      </div>
    </div>
  </section>

  <!-- Harita -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-extrabold text-koyu-900 text-center mb-8">Konumumuz</h2>
      <div class="rounded-2xl overflow-hidden shadow-lg h-80 md:h-96">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3017.0!2d29.2675766!3d40.8929624!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14cadb446eabc9a5%3A0xd6030b0d851dcd1f!2sEymen%20Reklam!5e0!3m2!1str!2str!4v1711000000000!5m2!1str!2str"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Eymen Reklam Konum"
        ></iframe>
      </div>
    </div>
  </section>

</BaseLayout>
