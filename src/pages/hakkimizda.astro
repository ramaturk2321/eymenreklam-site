---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contact } from '../lib/site-data';
---

<BaseLayout title="Hakkımızda — Tabela İmalatı Pendik İstanbul" description="Eymen Reklam — 2000'den beri Pendik İstanbul'da tabela imalatı ve dijital baskı. 2.500m² üretim tesisi, 25+ yıllık tecrübe.">

  <!-- Hero -->
  <section class="bg-koyu-900 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-eymen-400 text-sm font-semibold tracking-wider mb-3">EYMEN REKLAM</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Hakkımızda</h1>
      <p class="text-koyu-400 text-lg max-w-2xl mx-auto">
        2000'den bu yana İstanbul Pendik'te tabela imalatı ve dijital baskı sektöründe hizmet veriyoruz.
      </p>
    </div>
  </section>

  <!-- Hikaye -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Görsel -->
        <div class="relative">
          <img
            src="/images/fabrika.png"
            alt="Eymen Reklam Pendik Üretim Tesisi"
            class="rounded-2xl shadow-xl w-full"
          />
        </div>

        <!-- İçerik -->
        <div>
          <h2 class="text-3xl font-extrabold text-koyu-900 mb-6">Biz Kimiz?</h2>
          <div class="space-y-4 text-koyu-600 leading-relaxed">
            <p>
              <strong class="text-koyu-900">Eymen Reklam</strong>, Türkiye'nin önde gelen tabela, reklam ve baskı sektörü
              firmalarından biri olarak, geniş üretim kapasitesi ve uzman kadrosuyla hizmet vermektedir.
            </p>
            <p>
              Büyük ölçekli üretim tesislerimizde; vakum kabartma tabela, ayna krom tabela, kutu harf, totem,
              cephe giydirme, araç giydirme, afiş, bez baskı, branda baskı ve daha pek çok alanda
              profesyonel çözümler sunuyoruz.
            </p>
            <p class="italic border-l-4 border-eymen-500 pl-4 text-koyu-700">
              "Kaliteli malzeme, güçlü üretim altyapısı ve deneyimli ekibimizle, markanızı en etkili şekilde görünür kılıyoruz."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Rakamlar -->
  <section class="bg-koyu-50 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-extrabold text-eymen-500">25+</div>
          <div class="text-sm text-koyu-600 mt-2 font-medium">Yıllık Tecrübe</div>
        </div>
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-extrabold text-eymen-500">2.500m²</div>
          <div class="text-sm text-koyu-600 mt-2 font-medium">Üretim Tesisi</div>
        </div>
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-extrabold text-eymen-500">10.000+</div>
          <div class="text-sm text-koyu-600 mt-2 font-medium">Tamamlanan Proje</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Değerler -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-koyu-900 text-center mb-12">Neden Biz?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-8 bg-white rounded-2xl border border-koyu-100">
          <span class="text-4xl block mb-4">🏭</span>
          <h3 class="text-lg font-bold text-koyu-900 mb-3">Üretim Gücü</h3>
          <p class="text-sm text-koyu-500 leading-relaxed">Geniş üretim tesislerimiz ve modern makine parkurumuz sayesinde büyük hacimli siparişlerinizi zamanında ve kaliteli şekilde teslim ediyoruz.</p>
        </div>
        <div class="text-center p-8 bg-white rounded-2xl border border-koyu-100">
          <span class="text-4xl block mb-4">📏</span>
          <h3 class="text-lg font-bold text-koyu-900 mb-3">Sektörel Uzmanlık</h3>
          <p class="text-sm text-koyu-500 leading-relaxed">Yılların deneyimiyle; tabela, reklam ve baskı sektöründe edindiğimiz bilgi birikimini her projemize yansıtıyoruz.</p>
        </div>
        <div class="text-center p-8 bg-white rounded-2xl border border-koyu-100">
          <span class="text-4xl block mb-4">🤝</span>
          <h3 class="text-lg font-bold text-koyu-900 mb-3">Geniş Hizmet Ağı</h3>
          <p class="text-sm text-koyu-500 leading-relaxed">Tabela üretiminden dijital baskıya, araç giydirmeden kurumsal çözümlere kadar geniş bir hizmet yelpazesiyle yanınızdayız.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Belgelerimiz -->
  <section class="bg-koyu-50 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-eymen-500 text-sm font-semibold tracking-wider mb-3">KALİTE & GÜVENLİK</p>
        <h2 class="text-3xl font-extrabold text-koyu-900">Belgelerimiz</h2>
        <p class="text-koyu-500 text-lg max-w-2xl mx-auto mt-4">
          Firmamızın iş sağlığı ve güvenliği başta olmak üzere tüm yasal belge ve sertifikaları mevcuttur.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4 md:gap-6">
        <a href="/images/belgeler/isg-yuksekte-calisma-1.png" target="_blank" class="group">
          <div class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow border border-koyu-100">
            <img src="/images/belgeler/isg-yuksekte-calisma-1.png" alt="İSG Yüksekte Çalışma Eğitim Belgesi" class="w-full h-auto group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <p class="text-xs text-koyu-500 text-center mt-2 font-medium">Yüksekte Çalışma Eğitimi</p>
        </a>
        <a href="/images/belgeler/isg-temel-egitim.png" target="_blank" class="group">
          <div class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow border border-koyu-100">
            <img src="/images/belgeler/isg-temel-egitim.png" alt="İSG Temel Eğitim Belgesi" class="w-full h-auto group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <p class="text-xs text-koyu-500 text-center mt-2 font-medium">İSG Temel Eğitim</p>
        </a>
        <a href="/images/belgeler/isg-katilim-tutanagi.png" target="_blank" class="group">
          <div class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow border border-koyu-100">
            <img src="/images/belgeler/isg-katilim-tutanagi.png" alt="İSG Eğitim Katılım Tutanağı" class="w-full h-auto group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <p class="text-xs text-koyu-500 text-center mt-2 font-medium">Katılım Tutanağı</p>
        </a>
        <a href="/images/belgeler/isg-yuksekte-calisma-2.png" target="_blank" class="group">
          <div class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow border border-koyu-100">
            <img src="/images/belgeler/isg-yuksekte-calisma-2.png" alt="İSG Yüksekte Çalışma Eğitim Belgesi" class="w-full h-auto group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <p class="text-xs text-koyu-500 text-center mt-2 font-medium">Yüksekte Çalışma Eğitimi</p>
        </a>
        <a href="/images/belgeler/kurs-bitirme-belgesi.png" target="_blank" class="group">
          <div class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow border border-koyu-100">
            <img src="/images/belgeler/kurs-bitirme-belgesi.png" alt="Kurs Bitirme Belgesi" class="w-full h-auto group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <p class="text-xs text-koyu-500 text-center mt-2 font-medium">Kurs Bitirme Belgesi</p>
        </a>
      </div>
    </div>
  </section>

  <!-- İletişim CTA -->
  <section class="py-16 md:py-20 bg-eymen-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">Projenizi konuşalım</h2>
      <p class="text-eymen-50 text-lg mb-8 max-w-2xl mx-auto">
        Ücretsiz keşif ve teklif almak için bize ulaşın. Ekibimiz en kısa sürede size dönecektir.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/iletisim" class="bg-white text-eymen-600 hover:bg-koyu-50 px-8 py-4 rounded-xl font-semibold transition-colors">
          İletişime Geç
        </a>
        <a href={contact.phoneHref} class="bg-eymen-600 text-white hover:bg-eymen-700 px-8 py-4 rounded-xl font-semibold transition-colors">
          {contact.phone}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
