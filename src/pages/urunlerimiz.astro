---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  { id: 'all', label: 'Tümü' },
  { id: 'tabela', label: 'Tabela' },
  { id: 'folyo', label: 'Folyo & Araç' },
  { id: 'baski', label: 'Baskı' },
  { id: 'display', label: 'Display & Stand' },
  { id: 'magaza', label: 'Mağaza' },
];

const products = [
  // Tabela
  { title: 'Kutu Harf Tabela', category: 'tabela', image: '/images/kutu-harf.jpg', desc: 'LED aydınlatmalı 3D kutu harf. Paslanmaz, galvaniz veya alüminyum gövde.' },
  { title: 'Totem Tabela', category: 'tabela', image: '/images/tabela-imalat.jpg', desc: 'Bağımsız ayaklı totem tabela. AVM, fabrika girişi uygulamaları.' },
  { title: 'Çatı Tabelası', category: 'tabela', image: '/images/tabela-imalat.jpg', desc: 'Bina çatısına montajlı büyük ölçekli tabela sistemi.' },
  { title: 'Neon-Led Tabela', category: 'tabela', image: '/images/kutu-harf.jpg', desc: 'Neon görünümlü LED tabela. Retro estetik, modern teknoloji.' },
  { title: 'Işıklı Blok Tabela', category: 'tabela', image: '/images/tabela-imalat.jpg', desc: 'İçten aydınlatmalı kutu tabela. Vinileks veya pleksiglas yüzey.' },
  { title: 'Askılı Tabela', category: 'tabela', image: '/images/kutu-harf.jpg', desc: 'Çift taraflı askılı mağaza tabelası. Cadde cephesi uygulamaları.' },
  { title: 'Fener Tabela', category: 'tabela', image: '/images/tabela-imalat.jpg', desc: 'Işıklı fener tabela. Dışa dönük cephe uygulaması.' },
  { title: 'Vakum Tabela', category: 'tabela', image: '/images/tabela-imalat.jpg', desc: 'Vakum form tabela. Plastik malzeme ile 3D yüzey efekti.' },
  { title: 'Yönlendirme Tabelası', category: 'tabela', image: '/images/kutu-harf.jpg', desc: 'İç ve dış mekan yönlendirme tabela sistemi.' },
  { title: 'Ofis Tabelası', category: 'tabela', image: '/images/kutu-harf.jpg', desc: 'İç mekan kapı ve resepsiyon tabelaları.' },
  { title: 'İnşaat Tabelası', category: 'tabela', image: '/images/tabela-imalat.jpg', desc: 'Şantiye ve inşaat projesi tanıtım tabelaları.' },
  { title: 'Vinil Branda Germe Tabela', category: 'tabela', image: '/images/dijital-baski.jpg', desc: 'Vinil branda germe sistem tabela. Büyük yüzeyler için.' },

  // Folyo & Araç
  { title: 'Komple Araç Kaplama', category: 'folyo', image: '/images/arac-giydirme.jpg', desc: 'Cast folyo ile komple araç giydirme. Filo branding çözümleri.' },
  { title: 'Kısmi Araç Kaplama', category: 'folyo', image: '/images/arac-giydirme.jpg', desc: 'Kısmi araç kaplama. Logo, yazı ve grafik uygulamaları.' },
  { title: 'Kamyon / Tır Giydirme', category: 'folyo', image: '/images/arac-giydirme.jpg', desc: 'Ticari araç, kamyon ve TIR folyo giydirme uygulamaları.' },
  { title: 'Doblo Folyo Giydirme', category: 'folyo', image: '/images/arac-giydirme.jpg', desc: 'Doblo ve panelvan araç folyo giydirme çözümleri.' },
  { title: 'Cephe Folyo Giydirme', category: 'folyo', image: '/images/cephe-giydirme.jpg', desc: 'Bina cephesi folyo kaplama ve yenileme projeleri.' },
  { title: 'Cam Folyo Giydirme', category: 'folyo', image: '/images/cephe-giydirme.jpg', desc: 'Cam yüzeylere folyo uygulama. Güneş kontrol ve dekoratif.' },
  { title: 'Cam Kumlama Folyo', category: 'folyo', image: '/images/cephe-giydirme.jpg', desc: 'Kumlama efektli cam folyo. Ofis bölme ve mahremiyet çözümü.' },
  { title: 'Cam One Way Vision', category: 'folyo', image: '/images/cephe-giydirme.jpg', desc: 'Tek yön görüş folyo. Dışarıdan reklam, içeriden şeffaf görünüm.' },
  { title: 'Folyo Harf Kesim', category: 'folyo', image: '/images/cephe-giydirme.jpg', desc: 'Plotter kesim folyo harf ve şekil uygulamaları.' },
  { title: 'Özel Kesim Folyo Etiket', category: 'folyo', image: '/images/cephe-giydirme.jpg', desc: 'Özel kontur kesim folyo etiket ve sticker üretimi.' },

  // Baskı
  { title: 'Branda Baskı', category: 'baski', image: '/images/dijital-baski.jpg', desc: 'İç ve dış mekan branda baskı. Yüksek dayanım ve renk kalitesi.' },
  { title: 'Mesh Branda Baskı', category: 'baski', image: '/images/dijital-baski.jpg', desc: 'Delikli mesh branda baskı. Rüzgar geçirgen, büyük cepheler için.' },
  { title: 'Pankart Branda Baskı', category: 'baski', image: '/images/dijital-baski.jpg', desc: 'Açılış, kampanya ve etkinlik pankart branda baskı.' },
  { title: 'Afiş Baskı', category: 'baski', image: '/images/dijital-baski.jpg', desc: 'Vinil ve kağıt afiş baskı. İç ve dış mekan seçenekleri.' },
  { title: 'Mat Kağıt Poster', category: 'baski', image: '/images/dijital-baski.jpg', desc: 'Yüksek çözünürlük mat kağıt poster ve afiş baskı.' },
  { title: 'Fotoblok Baskı', category: 'baski', image: '/images/dijital-baski.jpg', desc: 'Köpük levha üzeri dijital baskı. Sunum ve sergileme için.' },
  { title: 'UV Baskı', category: 'baski', image: '/images/uv-baski.jpg', desc: 'Cam, metal, ahşap ve pleksiye doğrudan UV baskı.' },
  { title: 'Bez Kampanya Afişi', category: 'baski', image: '/images/dijital-baski.jpg', desc: 'Kumaş baskı kampanya ve tanıtım afişleri.' },

  // Display
  { title: 'Lightbox Pano', category: 'display', image: '/images/dijital-baski.jpg', desc: 'İçten aydınlatmalı ışıklı reklam panosu. İç ve dış mekan.' },
  { title: 'Roll-Up Banner', category: 'display', image: '/images/dijital-baski.jpg', desc: 'Taşınabilir roll-up banner sistemi. Fuar ve etkinlik için.' },
  { title: 'X Banner', category: 'display', image: '/images/dijital-baski.jpg', desc: 'Ekonomik X banner standı. Hızlı kurulum.' },
  { title: 'Fuar Standı', category: 'display', image: '/images/dijital-baski.jpg', desc: 'Özel tasarım fuar standı. Modüler ve kalıcı çözümler.' },

  // Mağaza
  { title: 'Mağaza Konsept Tasarım', category: 'magaza', image: '/images/cephe-giydirme.jpg', desc: 'Anahtar teslim mağaza iç ve dış mekan branding tasarımı.' },
  { title: 'Vitrin Düzenleme', category: 'magaza', image: '/images/cephe-giydirme.jpg', desc: 'Mağaza vitrin tasarımı ve uygulama hizmetleri.' },
  { title: 'İş Güvenliği Levhaları', category: 'magaza', image: '/images/tabela-imalat.jpg', desc: 'İSG mevzuatına uygun uyarı, yasak ve bilgi levhaları.' },
];
---

<BaseLayout title="Ürünlerimiz" description="Eymen Reklam ürün kataloğu — Tabela, UV baskı, araç giydirme, dijital baskı, folyo ve daha fazlası. 25 yıllık tecrübe ile üretim.">

  <!-- Hero -->
  <section class="bg-koyu-900 pt-32 pb-16 md:pt-40 md:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-eymen-400 text-sm font-semibold uppercase tracking-wider mb-3">Ürün Kataloğu</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Ürünlerimiz</h1>
      <p class="text-koyu-400 text-lg max-w-2xl mx-auto">
        25 yılda 10.000'den fazla projede kullandığımız ürün yelpazesi. Kategori seçerek filtreleyebilirsiniz.
      </p>
    </div>
  </section>

  <!-- Filtre + Grid -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Filtre Butonları -->
      <div class="flex flex-wrap gap-2 mb-10 justify-center" id="filter-buttons">
        {categories.map(cat => (
          <button
            data-filter={cat.id}
            class:list={[
              'filter-btn px-5 py-2.5 rounded-full text-sm font-medium transition-all border',
              cat.id === 'all'
                ? 'bg-eymen-500 text-white border-eymen-500'
                : 'bg-white text-koyu-600 border-koyu-200 hover:border-eymen-300 hover:text-eymen-600'
            ]}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Ürün Sayacı -->
      <p class="text-sm text-koyu-400 mb-6" id="product-count">{products.length} ürün gösteriliyor</p>

      <!-- Ürün Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5" id="product-grid">
        {products.map(product => (
          <div class="product-card group" data-category={product.category}>
            <div class="bg-white rounded-2xl border border-koyu-100 overflow-hidden hover:shadow-lg hover:border-eymen-200 transition-all duration-300 hover:-translate-y-1">
              <div class="aspect-[4/3] overflow-hidden bg-koyu-200">
                <img src={product.image} alt={product.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
              <div class="p-4">
                <h3 class="font-bold text-koyu-900 text-sm mb-1 group-hover:text-eymen-600 transition-colors">{product.title}</h3>
                <p class="text-xs text-koyu-500 leading-relaxed mb-3">{product.desc}</p>
                <a
                  href={`/teklif-al`}
                  class="inline-flex items-center gap-1.5 text-xs text-eymen-600 font-semibold hover:text-eymen-700 transition-colors"
                >
                  Teklif Al
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-koyu-900 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white mb-4">Özel Projeniz İçin Teklif Alın</h2>
      <p class="text-koyu-400 mb-8">Listemizde olmayan özel projeler için de çözüm üretiyoruz. Kurumsal teklif formunu doldurun, 24 saat içinde dönüş yapalım.</p>
      <a href="/teklif-al" class="inline-flex items-center gap-2 bg-eymen-500 hover:bg-eymen-600 text-white px-8 py-4 rounded-xl text-base font-bold transition-all hover:shadow-lg hover:shadow-eymen-500/25">
        Kurumsal Teklif Al
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.product-card');
  const countEl = document.getElementById('product-count');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      buttons.forEach(b => {
        b.classList.remove('bg-eymen-500', 'text-white', 'border-eymen-500');
        b.classList.add('bg-white', 'text-koyu-600', 'border-koyu-200');
      });
      btn.classList.remove('bg-white', 'text-koyu-600', 'border-koyu-200');
      btn.classList.add('bg-eymen-500', 'text-white', 'border-eymen-500');

      let visible = 0;
      cards.forEach(card => {
        const category = card.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          card.style.display = '';
          visible++;
        } else {
          card.style.display = 'none';
        }
      });

      if (countEl) countEl.textContent = `${visible} ürün gösteriliyor`;
    });
  });
</script>
