---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Kategori eşleme: Content Collection category → filtre ID
const categoryMap: Record<string, string> = {
  'Tabela': 'tabela',
  'UV Baskı': 'baski',
  'Folyo & Giydirme': 'folyo',
  'Bez & Afiş Baskı': 'baski',
  'Display & Stand': 'display',
};

const categories = [
  { id: 'all', label: 'Tümü' },
  { id: 'tabela', label: 'Tabela' },
  { id: 'folyo', label: 'Folyo & Araç' },
  { id: 'baski', label: 'Baskı' },
  { id: 'display', label: 'Display & Stand' },
];

const urunler = await getCollection('urunler');
const products = urunler.map(u => ({
  title: u.data.title,
  category: categoryMap[u.data.category] || 'tabela',
  image: u.data.mainImg,
  desc: u.data.shortDesc,
  href: `/urunlerimiz/${u.id}/`,
}));
---

<BaseLayout title="Tabela ve Reklam Ürünleri Pendik İstanbul" description="Eymen Reklam ürün kataloğu — Kutu harf tabela, totem tabela, UV baskı, araç giydirme, dijital baskı ve folyo ürünleri. Pendik İstanbul'da 25 yıllık üretim tecrübesi.">

  <!-- Hero -->
  <section class="bg-koyu-900 pt-32 pb-16 md:pt-40 md:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-eymen-400 text-sm font-semibold uppercase tracking-wider mb-3">Ürün Kataloğu</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Tabela ve Reklam Ürünleri</h1>
      <p class="text-koyu-400 text-lg max-w-2xl mx-auto">
        Pendik İstanbul'da 25 yılda 10.000'den fazla projede kullandığımız tabela ve reklam ürünleri. Kategori seçerek filtreleyebilirsiniz.
      </p>
    </div>
  </section>

  <!-- Filtre + Grid -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Filtre Butonları -->
      <div class="flex flex-wrap gap-2 mb-10 justify-center" id="filter-buttons">
        {categories.map(cat => (
          <button
            data-filter={cat.id}
            class:list={[
              'filter-btn px-5 py-2.5 rounded-full text-sm font-medium transition-all border',
              cat.id === 'all'
                ? 'bg-eymen-500 text-white border-eymen-500'
                : 'bg-white text-koyu-600 border-koyu-200 hover:border-eymen-300 hover:text-eymen-600'
            ]}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Ürün Sayacı -->
      <p class="text-sm text-koyu-400 mb-6" id="product-count">{products.length} ürün gösteriliyor</p>

      <!-- Ürün Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5" id="product-grid">
        {products.map(product => (
          <div class="product-card group" data-category={product.category} data-search={`${product.title} ${product.desc}`.toLocaleLowerCase('tr-TR')}>
            <div class="bg-white rounded-2xl border border-koyu-100 overflow-hidden hover:shadow-lg hover:border-eymen-200 transition-all duration-300 hover:-translate-y-1">
              <div class="aspect-[4/3] overflow-hidden bg-koyu-200">
                <img src={product.image} alt={product.title} width="400" height="300" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="p-4">
                <h3 class="font-bold text-koyu-900 text-sm mb-1 group-hover:text-eymen-600 transition-colors">{product.title}</h3>
                <p class="text-xs text-koyu-500 leading-relaxed mb-3 line-clamp-2">{product.desc}</p>
                <a
                  href={product.href}
                  class="inline-flex items-center gap-1.5 text-xs text-eymen-600 font-semibold hover:text-eymen-700 transition-colors"
                >
                  Detaylı Bilgi
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
      <p class="hidden text-center text-koyu-500 bg-koyu-50 rounded-xl border border-koyu-100 p-6 mt-8" id="no-results">
        Aramanızla eşleşen ürün bulunamadı.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-koyu-900 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-extrabold text-white mb-4">Özel Projeniz İçin Teklif Alın</h2>
      <p class="text-koyu-400 mb-8">Listemizde olmayan özel projeler için de çözüm üretiyoruz. Kurumsal teklif formunu doldurun, 24 saat içinde dönüş yapalım.</p>
      <a href="/teklif-al" class="inline-flex items-center gap-2 bg-eymen-500 hover:bg-eymen-600 text-white px-8 py-4 rounded-xl text-base font-bold transition-all hover:shadow-lg hover:shadow-eymen-500/25">
        Kurumsal Teklif Al
      </a>
    </div>
  </section>

</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.product-card');
  const countEl = document.getElementById('product-count');
  const noResultsEl = document.getElementById('no-results');
  const searchParams = new URLSearchParams(window.location.search);
  const searchTerm = (searchParams.get('q') || '').trim();
  const normalizedSearch = searchTerm.toLocaleLowerCase('tr-TR');
  let activeFilter = 'all';

  function updateProducts() {
    let visible = 0;

    cards.forEach(card => {
      const category = card.getAttribute('data-category');
      const searchText = card.getAttribute('data-search') || '';
      const matchesCategory = activeFilter === 'all' || category === activeFilter;
      const matchesSearch = !normalizedSearch || searchText.includes(normalizedSearch);

      if (matchesCategory && matchesSearch) {
        card.style.display = '';
        visible++;
      } else {
        card.style.display = 'none';
      }
    });

    if (countEl) {
      countEl.textContent = searchTerm
        ? `${visible} ürün gösteriliyor - "${searchTerm}" araması`
        : `${visible} ürün gösteriliyor`;
    }

    noResultsEl?.classList.toggle('hidden', visible > 0);
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      activeFilter = btn.getAttribute('data-filter') || 'all';

      buttons.forEach(b => {
        b.classList.remove('bg-eymen-500', 'text-white', 'border-eymen-500');
        b.classList.add('bg-white', 'text-koyu-600', 'border-koyu-200');
      });
      btn.classList.remove('bg-white', 'text-koyu-600', 'border-koyu-200');
      btn.classList.add('bg-eymen-500', 'text-white', 'border-eymen-500');

      updateProducts();
    });
  });

  updateProducts();
</script>
