---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { contact, getWhatsAppUrl, whatsappMessages, whatsappIcon } from '../lib/site-data';

const projeler = (await getCollection('projeler')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Tüm benzersiz kategorileri çıkar + proje sayısını hesapla
const categoryCount: Record<string, number> = {};
projeler.forEach(p => p.data.categories.forEach(cat => {
  categoryCount[cat] = (categoryCount[cat] || 0) + 1;
}));
const allCategories = Object.entries(categoryCount).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tabela ve Reklam Projeleri Pendik İstanbul" description="Eymen Reklam proje galerisi — Pendik İstanbul'da 25 yılda tamamlanan tabela imalatı, UV baskı, araç giydirme ve dijital baskı projelerimiz.">

  <!-- Hero -->
  <section class="bg-koyu-900 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-eymen-400 text-sm font-semibold tracking-wider mb-3">25 YILLIK PORTFÖY</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Tabela ve Reklam Projelerimiz</h1>
      <p class="text-koyu-400 text-lg max-w-2xl mx-auto">
        Pendik İstanbul'da kurumsal müşterilerimiz için tamamladığımız tabela, UV baskı ve araç giydirme projelerinden örnekler.
      </p>
    </div>
  </section>

  <!-- İki Kolonlu: Sidebar + Grid -->
  <section class="py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-8 lg:gap-10">

        <!-- SOL: Sticky Sidebar -->
        <aside class="hidden lg:block">
          <div class="sticky top-24 space-y-6">

            <!-- Kategori Filtresi -->
            <div class="bg-koyu-50 rounded-xl p-5 border border-koyu-100">
              <h3 class="text-sm font-bold text-koyu-900 tracking-wider mb-3">KATEGORİLER</h3>
              <div class="space-y-1">
                <button
                  class="filter-btn active w-full flex items-center justify-between px-3 py-2.5 rounded-lg text-sm font-medium transition-all"
                  data-category="all"
                >
                  <span>Tümü</span>
                  <span class="cat-count text-xs bg-koyu-200 text-koyu-600 px-2 py-0.5 rounded-full">{projeler.length}</span>
                </button>
                {allCategories.map(([cat, count]) => (
                  <button
                    class="filter-btn w-full flex items-center justify-between px-3 py-2.5 rounded-lg text-sm font-medium transition-all"
                    data-category={cat}
                  >
                    <span>{cat}</span>
                    <span class="cat-count text-xs bg-koyu-200 text-koyu-600 px-2 py-0.5 rounded-full">{count}</span>
                  </button>
                ))}
              </div>
            </div>

            <!-- CTA -->
            <div class="bg-eymen-500 rounded-xl p-5 text-white">
              <h3 class="font-bold mb-2">Projeniz mi Var?</h3>
              <p class="text-sm text-eymen-100 mb-4 leading-relaxed">
                Ücretsiz keşif ve fiyat teklifi için hemen bize ulaşın.
              </p>
              <a
                href={getWhatsAppUrl(whatsappMessages.proje)}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1fb855] text-white px-4 py-2.5 rounded-lg text-sm font-bold transition-all w-full mb-2"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d={whatsappIcon}/></svg>
                WhatsApp ile Yaz
              </a>
              <a
                href={contact.phoneHref}
                class="flex items-center justify-center gap-2 bg-white/15 hover:bg-white/25 text-white px-4 py-2.5 rounded-lg text-sm font-semibold transition-all w-full"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                {contact.phone}
              </a>
            </div>

            <!-- Rakamlar -->
            <div class="grid grid-cols-2 gap-2">
              <div class="bg-koyu-900 rounded-lg p-3 text-center">
                <div class="text-xl font-extrabold text-eymen-500">25+</div>
                <div class="text-[10px] text-koyu-400 mt-0.5">Yıl Tecrübe</div>
              </div>
              <div class="bg-koyu-900 rounded-lg p-3 text-center">
                <div class="text-xl font-extrabold text-eymen-500">10K+</div>
                <div class="text-[10px] text-koyu-400 mt-0.5">Proje</div>
              </div>
              <div class="bg-koyu-900 rounded-lg p-3 text-center">
                <div class="text-xl font-extrabold text-eymen-500">500+</div>
                <div class="text-[10px] text-koyu-400 mt-0.5">Müşteri</div>
              </div>
              <div class="bg-koyu-900 rounded-lg p-3 text-center">
                <div class="text-xl font-extrabold text-eymen-500">2.5K</div>
                <div class="text-[10px] text-koyu-400 mt-0.5">m² Tesis</div>
              </div>
            </div>

          </div>
        </aside>

        <!-- SAĞ: Proje Grid -->
        <div>
          <!-- Mobil Kategori Filtresi -->
          <div class="lg:hidden flex flex-wrap gap-2 mb-6" id="mobil-filtre">
            <button
              class="filter-btn active px-4 py-2 rounded-full text-sm font-semibold transition-all border border-koyu-200"
              data-category="all"
            >
              Tümü ({projeler.length})
            </button>
            {allCategories.map(([cat, count]) => (
              <button
                class="filter-btn px-4 py-2 rounded-full text-sm font-semibold transition-all border border-koyu-200"
                data-category={cat}
              >
                {cat} ({count})
              </button>
            ))}
          </div>

          <!-- Aktif filtre başlığı -->
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-lg font-bold text-koyu-900" id="grid-title">
              Tüm Projeler <span class="text-koyu-400 font-normal text-base">({projeler.length})</span>
            </h2>
          </div>

          <!-- Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6" id="proje-grid">
            {projeler.map(project => (
              <a
                href={`/projelerimiz/${project.id}/`}
                class="proje-kart group bg-white rounded-2xl border border-koyu-100 overflow-hidden hover:shadow-xl hover:border-eymen-200 transition-all duration-300 hover:-translate-y-1"
                data-categories={JSON.stringify(project.data.categories)}
              >
                <div class="aspect-[4/3] overflow-hidden relative">
                  <img
                    src={project.data.image}
                    alt={project.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                  <div class="absolute top-3 left-3 flex flex-wrap gap-1.5">
                    {project.data.categories.map(cat => (
                      <span class="px-3 py-1 bg-eymen-500 text-white text-xs font-semibold rounded-full">
                        {cat}
                      </span>
                    ))}
                  </div>
                </div>
                <div class="p-5">
                  <h3 class="font-bold text-koyu-900 mb-2 group-hover:text-eymen-600 transition-colors">{project.data.title}</h3>
                  <p class="text-sm text-koyu-500 leading-relaxed line-clamp-2">{project.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Alt CTA -->
  <section class="bg-gradient-to-br from-eymen-500 to-eymen-700 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-3">Sizin Projeniz de Burada Olsun</h2>
      <p class="text-eymen-100 mb-6">Markanız için özel çözümler üretiyoruz. Ücretsiz keşif ve teklif alın.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/teklif-al" class="inline-flex items-center justify-center gap-2 bg-white text-eymen-600 hover:bg-koyu-50 px-8 py-3.5 rounded-xl text-base font-bold transition-all">
          Kurumsal Teklif Formu
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href={contact.phoneHref} class="inline-flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white/60 text-white px-8 py-3.5 rounded-xl text-base font-semibold transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {contact.phone}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .filter-btn {
    background: white;
    color: var(--color-koyu-600);
  }
  .filter-btn:hover {
    background: var(--color-koyu-50);
    color: var(--color-eymen-600);
  }
  .filter-btn.active {
    background: var(--color-eymen-500);
    color: white;
    border-color: var(--color-eymen-500);
  }
  .filter-btn.active .cat-count {
    background: rgba(255,255,255,0.25);
    color: white;
  }
  .proje-kart.hidden {
    display: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.proje-kart');
    const gridTitle = document.getElementById('grid-title');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.dataset.category;

        // Tüm butonları güncelle (hem sidebar hem mobil)
        buttons.forEach(b => {
          if (b.dataset.category === category) {
            b.classList.add('active');
          } else {
            b.classList.remove('active');
          }
        });

        // Kartları filtrele
        let visibleCount = 0;
        cards.forEach(card => {
          if (category === 'all') {
            card.classList.remove('hidden');
            visibleCount++;
          } else {
            const cats: string[] = JSON.parse(card.dataset.categories || '[]');
            const show = cats.includes(category!);
            card.classList.toggle('hidden', !show);
            if (show) visibleCount++;
          }
        });

        // Başlığı güncelle
        if (gridTitle) {
          const label = category === 'all' ? 'Tüm Projeler' : category;
          gridTitle.innerHTML = `${label} <span class="text-koyu-400 font-normal text-base">(${visibleCount})</span>`;
        }
      });
    });
  });
</script>
