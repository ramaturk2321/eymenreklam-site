---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contact } from '../lib/site-data';

const hizmetler = [
  'Kutu Harf Tabela', 'Totem Tabela', 'Çatı Tabelası', 'Cephe Tabelası',
  'UV Baskı', 'Dijital Baskı', 'Araç Giydirme', 'Cephe Giydirme',
  'Branda Baskı', 'Afiş Baskı', 'Cam Folyo', 'Lightbox Pano',
  'Mağaza Konsept', 'İş Güvenliği Levhaları', 'Fuar Standı', 'Diğer'
];
---

<BaseLayout title="Kurumsal Teklif Al — Tabela ve Reklam Pendik İstanbul" description="Pendik İstanbul'da tabela imalatı, UV baskı, araç giydirme ve tüm reklam çözümleriniz için ücretsiz keşif ve profesyonel teklif alın. Eymen Reklam.">

  <!-- Hero -->
  <section class="bg-koyu-900 pt-32 pb-12 md:pt-40 md:pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-eymen-400 text-sm font-semibold uppercase tracking-wider mb-3">Kurumsal İletişim</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Kurumsal Teklif Alın</h1>
      <p class="text-koyu-400 text-lg max-w-2xl mx-auto">
        Projenizin detaylarını paylaşın, 24 saat içinde size özel fiyat teklifi ve 3D ön izleme ile dönüş yapalım.
      </p>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Form -->
        <div class="lg:col-span-2">
          <form class="space-y-6" id="teklif-form" action="https://api.web3forms.com/submit" method="POST">
            <input type="hidden" name="access_key" value="6eef2241-f453-4dd5-8881-0566fadae644" />
            <input type="hidden" name="subject" value="Eymen Reklam — Kurumsal Teklif Talebi" />
            <input type="hidden" name="from_name" value="Eymen Reklam Website" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
            <!-- Firma Bilgileri -->
            <div>
              <h3 class="text-lg font-bold text-koyu-900 mb-4 pb-2 border-b border-koyu-100">Firma Bilgileri</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-koyu-700 mb-1">Firma Adı *</label>
                  <input type="text" name="firma" required class="w-full px-4 py-3 rounded-xl border border-koyu-200 focus:border-eymen-500 focus:ring-2 focus:ring-eymen-500/20 outline-none transition-all text-sm" placeholder="ABC Perakende A.Ş." />
                </div>
                <div>
                  <label class="block text-sm font-medium text-koyu-700 mb-1">Sektör</label>
                  <select name="sektor" class="w-full px-4 py-3 rounded-xl border border-koyu-200 focus:border-eymen-500 focus:ring-2 focus:ring-eymen-500/20 outline-none transition-all text-sm">
                    <option>Seçiniz</option>
                    <option>Perakende & AVM</option>
                    <option>Sanayi & Fabrika</option>
                    <option>Sağlık & Hastane</option>
                    <option>Eğitim & Kamu</option>
                    <option>Otel & Restaurant</option>
                    <option>Banka & Finans</option>
                    <option>Otomotiv</option>
                    <option>İnşaat & Gayrimenkul</option>
                    <option>Diğer</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- İletişim -->
            <div>
              <h3 class="text-lg font-bold text-koyu-900 mb-4 pb-2 border-b border-koyu-100">İletişim Bilgileri</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-koyu-700 mb-1">Ad Soyad *</label>
                  <input type="text" name="ad_soyad" required class="w-full px-4 py-3 rounded-xl border border-koyu-200 focus:border-eymen-500 focus:ring-2 focus:ring-eymen-500/20 outline-none transition-all text-sm" placeholder="Ahmet Yılmaz" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-koyu-700 mb-1">Unvan / Pozisyon</label>
                  <input type="text" name="unvan" class="w-full px-4 py-3 rounded-xl border border-koyu-200 focus:border-eymen-500 focus:ring-2 focus:ring-eymen-500/20 outline-none transition-all text-sm" placeholder="Satınalma Müdürü" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-koyu-700 mb-1">E-posta *</label>
                  <input type="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-koyu-200 focus:border-eymen-500 focus:ring-2 focus:ring-eymen-500/20 outline-none transition-all text-sm" placeholder="ahmet@firma.com" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-koyu-700 mb-1">Telefon *</label>
                  <input type="tel" name="telefon" required class="w-full px-4 py-3 rounded-xl border border-koyu-200 focus:border-eymen-500 focus:ring-2 focus:ring-eymen-500/20 outline-none transition-all text-sm" placeholder="0532 XXX XX XX" />
                </div>
              </div>
            </div>

            <!-- Proje Detayları -->
            <div>
              <h3 class="text-lg font-bold text-koyu-900 mb-4 pb-2 border-b border-koyu-100">Proje Detayları</h3>
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-koyu-700 mb-2">İhtiyaç Duyduğunuz Hizmet(ler) *</label>
                  <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
                    {hizmetler.map(h => (
                      <label class="flex items-center gap-2 px-3 py-2 rounded-lg border border-koyu-200 hover:border-eymen-300 cursor-pointer transition-colors text-sm">
                        <input type="checkbox" name="hizmetler" value={h} class="rounded border-koyu-300 text-eymen-500 focus:ring-eymen-500" />
                        <span class="text-koyu-600">{h}</span>
                      </label>
                    ))}
                  </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-koyu-700 mb-1">Proje Lokasyonu</label>
                    <input type="text" name="lokasyon" class="w-full px-4 py-3 rounded-xl border border-koyu-200 focus:border-eymen-500 focus:ring-2 focus:ring-eymen-500/20 outline-none transition-all text-sm" placeholder="İstanbul / Pendik" />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-koyu-700 mb-1">Termin Beklentisi</label>
                    <select name="termin" class="w-full px-4 py-3 rounded-xl border border-koyu-200 focus:border-eymen-500 focus:ring-2 focus:ring-eymen-500/20 outline-none transition-all text-sm">
                      <option>Seçiniz</option>
                      <option>Acil (1 hafta içinde)</option>
                      <option>Kısa vade (2-3 hafta)</option>
                      <option>Normal (1 ay)</option>
                      <option>Planlama aşamasında</option>
                    </select>
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-koyu-700 mb-1">Proje Açıklaması</label>
                  <textarea rows="4" name="aciklama" class="w-full px-4 py-3 rounded-xl border border-koyu-200 focus:border-eymen-500 focus:ring-2 focus:ring-eymen-500/20 outline-none transition-all text-sm resize-none" placeholder="Projeniz hakkında detay verin. Boyut, adet, malzeme tercihi, özel istekleriniz..."></textarea>
                </div>
              </div>
            </div>

            <!-- Submit -->
            <div class="pt-4">
              <button type="submit" class="w-full md:w-auto inline-flex items-center justify-center gap-2 bg-eymen-500 hover:bg-eymen-600 text-white px-10 py-4 rounded-xl text-base font-bold transition-all hover:shadow-lg hover:shadow-eymen-500/25">
                Teklif Talebini Gönder
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </button>
              <p class="text-xs text-koyu-400 mt-3">* Bilgileriniz gizli tutulur ve sadece teklif hazırlama amacıyla kullanılır.</p>
            </div>
          </form>
        </div>

        <!-- Sidebar Info -->
        <div class="space-y-6">
          <!-- Neden Biz -->
          <div class="bg-koyu-50 rounded-2xl p-6 border border-koyu-100">
            <h3 class="font-bold text-koyu-900 mb-4">Neden Kurumsal Teklif?</h3>
            <div class="space-y-3 text-sm text-koyu-600">
              <div class="flex items-start gap-3">
                <span class="text-eymen-500 mt-0.5">✓</span>
                <span>Detaylı maliyet analizi ve kalem bazlı fiyatlandırma</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-eymen-500 mt-0.5">✓</span>
                <span>3D ön izleme ile projenizi önceden görün</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-eymen-500 mt-0.5">✓</span>
                <span>Proforma fatura ve resmi teklif mektubu</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-eymen-500 mt-0.5">✓</span>
                <span>KDV dahil / hariç şeffaf fiyat politikası</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-eymen-500 mt-0.5">✓</span>
                <span>24 saat içinde e-posta ile dönüş garantisi</span>
              </div>
            </div>
          </div>

          <!-- İletişim -->
          <div class="bg-eymen-500 rounded-2xl p-6 text-white">
            <h3 class="font-bold mb-4">Hemen Arayın</h3>
            <div class="space-y-3 text-sm">
              <a href={contact.phoneHref} class="flex items-center gap-3 hover:text-eymen-100 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                {contact.phone}
              </a>
              <a href={contact.mobileHref} class="flex items-center gap-3 hover:text-eymen-100 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                {contact.mobile}
              </a>
              <a href={contact.emailHref} class="flex items-center gap-3 hover:text-eymen-100 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                {contact.email}
              </a>
            </div>
          </div>

          <!-- Adres -->
          <div class="bg-koyu-50 rounded-2xl p-6 border border-koyu-100">
            <h3 class="font-bold text-koyu-900 mb-3">Fabrika & Showroom</h3>
            <p class="text-sm text-koyu-600 leading-relaxed">
              Eymen Reklam Üretim Tesisi<br />
              Pendik, İstanbul<br />
              2.500m² kapalı üretim alanı
            </p>
            <p class="text-xs text-koyu-400 mt-3">Pazartesi – Cumartesi: 08:30 – 18:30</p>
          </div>

          <!-- Rakamlar -->
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-koyu-900 rounded-xl p-4 text-center">
              <div class="text-2xl font-extrabold text-eymen-500">25+</div>
              <div class="text-xs text-koyu-400 mt-1">Yıl Tecrübe</div>
            </div>
            <div class="bg-koyu-900 rounded-xl p-4 text-center">
              <div class="text-2xl font-extrabold text-eymen-500">10K+</div>
              <div class="text-xs text-koyu-400 mt-1">Proje</div>
            </div>
            <div class="bg-koyu-900 rounded-xl p-4 text-center">
              <div class="text-2xl font-extrabold text-eymen-500">500+</div>
              <div class="text-xs text-koyu-400 mt-1">Müşteri</div>
            </div>
            <div class="bg-koyu-900 rounded-xl p-4 text-center">
              <div class="text-2xl font-extrabold text-eymen-500">2.5K</div>
              <div class="text-xs text-koyu-400 mt-1">m² Tesis</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
